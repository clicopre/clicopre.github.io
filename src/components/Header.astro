---
import SignatureStrip from './SignatureStrip.astro';

const nav = [
  { href: '#research', label: 'Research', n: 'I'   },
  { href: '#approach', label: 'Approach', n: 'II'  },
  { href: '#people',   label: 'People',   n: 'III' },
  { href: '#outputs',  label: 'Outputs',  n: 'IV'  },
  { href: '#updates',  label: 'Updates',  n: 'V'   },
  { href: '#contact',  label: 'Contact',  n: 'VI'  },
];
---

<header class="site-header" data-nav-open="false">
  <SignatureStrip class="site-header__stripes" />

  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="CLICOPRE — home">
      <span class="brand__word">CLICOPRE</span>
    </a>

    <span class="site-header__sep" aria-hidden="true"></span>

    <!-- Desktop nav inline; mobile nav rendered as sibling overlay below. -->
    <nav class="site-nav site-nav--inline" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href}>
              <span class="site-nav__num">{item.n}</span>
              <span class="site-nav__label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-controls="primary-nav"
      aria-expanded="false"
      aria-label="Open menu"
    >
      <span class="nav-toggle__bar" aria-hidden="true"></span>
      <span class="nav-toggle__bar" aria-hidden="true"></span>
      <span class="nav-toggle__bar" aria-hidden="true"></span>
      <span class="nav-toggle__label">Menu</span>
    </button>
  </div>
</header>

<!-- Nav rendered as sibling of header so the fixed-position mobile overlay
     does not get trapped inside header's stacking context. -->
<nav id="primary-nav" class="site-nav" aria-label="Primary">
  <ul>
    {nav.map((item) => (
      <li>
        <a href={item.href}>
          <span class="site-nav__num">{item.n}</span>
          <span class="site-nav__label">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  // Mobile nav toggle — vanilla, no framework.
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.querySelector<HTMLElement>('#primary-nav');

  if (header && toggle && nav) {
    const label = toggle.querySelector<HTMLElement>('.nav-toggle__label');
    const setOpen = (open: boolean) => {
      header.dataset.navOpen = open ? 'true' : 'false';
      document.documentElement.dataset.navOpen = open ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (label) label.textContent = open ? 'Close' : 'Menu';
      document.documentElement.style.overflow = open ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => {
      setOpen(header.dataset.navOpen !== 'true');
    });
    // close after clicking any nav link + focus the target section heading
    nav.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a');
      if (link) {
        setOpen(false);
        const id = link.getAttribute('href')?.replace('#', '');
        if (id) {
          const section = document.getElementById(id);
          if (section) {
            const heading = section.querySelector('h2, h3');
            if (heading) {
              heading.setAttribute('tabindex', '-1');
              setTimeout(() => (heading as HTMLElement).focus({ preventScroll: true }), 400);
            }
          }
        }
      }
    });
    // close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.dataset.navOpen === 'true') {
        setOpen(false);
        toggle.focus();
      }
      // focus trap when mobile nav is open
      if (e.key === 'Tab' && header.dataset.navOpen === 'true') {
        const focusable = [toggle, ...nav.querySelectorAll<HTMLElement>('a')];
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }

  // Desktop inline nav — focus heading on click
  const inlineNav = document.querySelector<HTMLElement>('.site-nav--inline');
  if (inlineNav) {
    inlineNav.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a');
      if (!link) return;
      const id = link.getAttribute('href')?.replace('#', '');
      if (!id) return;
      const section = document.getElementById(id);
      if (!section) return;
      const heading = section.querySelector('h2, h3');
      if (heading) {
        heading.setAttribute('tabindex', '-1');
        setTimeout(() => (heading as HTMLElement).focus({ preventScroll: true }), 400);
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--c-bg) 92%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--c-line);
  }

  .site-header__stripes {
    height: 4px;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1.4rem;
    padding-block: 1.1rem 1.05rem;
  }

  /* Push the mobile toggle / right-side controls to the far right. */
  .site-header__inner > .nav-toggle { margin-left: auto; }
  .site-header__inner > .site-nav--inline { margin-left: auto; }

  /* ── Brand wordmark — single-line caps editorial wordmark ────── */
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    color: var(--c-ink);
    line-height: 1;
    flex-shrink: 0;
  }
  .brand__word {
    font-family: var(--f-display);
    font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 0;
    font-weight: 420;
    font-size: 1.32rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .brand__sub {
    font-family: var(--f-mono);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
    /* hide on small viewports for breathing room */
  }
  @media (max-width: 1080px) {
    .brand__sub { display: none; }
  }

  /* ── Vertical separator between brand and nav ──────────────── */
  .site-header__sep {
    display: inline-block;
    width: 1px;
    height: 1.6rem;
    background: var(--c-line-strong);
    align-self: center;
    flex-shrink: 0;
  }
  @media (max-width: 760px) {
    .site-header__sep { display: none; }
  }

  /* ── Nav with roman numerals ─────────────────────────── */
  /* The mobile overlay #primary-nav lives outside the header so it can
     escape the sticky stacking context. On desktop we hide it and rely
     on the inline .site-nav--inline copy. */
  #primary-nav { display: none; }
  @media (max-width: 760px) {
    #primary-nav { display: block; }
  }

  .site-nav ul {
    display: flex;
    gap: clamp(0.9rem, 2.2vw, 1.9rem);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .site-nav a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    font-family: var(--f-sans);
    font-size: 0.84rem;
    font-weight: 400;
    color: var(--c-ink-soft);
    padding: 0.5rem 0;
    position: relative;
  }
  .site-nav__num {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 400;
    color: var(--c-ink-muted);
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }
  .site-nav__label {
    transition: color 0.3s ease;
  }
  .site-nav a::after {
    content: "";
    position: absolute;
    left: 0; right: 100%;
    bottom: 0.18rem;
    height: 1px;
    background: var(--c-teal);
    transition: right 0.45s var(--ease);
  }
  .site-nav a:hover,
  .site-nav a:focus-visible { color: var(--c-ink); }
  .site-nav a:hover .site-nav__num,
  .site-nav a:focus-visible .site-nav__num { color: var(--c-teal-deep); }
  .site-nav a:hover::after,
  .site-nav a:focus-visible::after,
  .site-nav a.is-active::after { right: 0; }
  .site-nav a.is-active { color: var(--c-ink); }
  .site-nav a.is-active .site-nav__num { color: var(--c-teal-deep); }
  .site-nav a:focus-visible {
    outline: 2px solid var(--c-teal-deep);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ── Mobile nav toggle (button) ──────────────────────── */
  .nav-toggle {
    display: none;
    align-items: center;
    gap: 0.55rem;
    background: transparent;
    border: 1px solid var(--c-line-strong);
    color: var(--c-ink);
    padding: 0.55rem 0.85rem 0.55rem 0.7rem;
    cursor: pointer;
    font-family: var(--f-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    line-height: 1;
  }
  .nav-toggle__bar-stack {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
  }
  .nav-toggle__bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--c-ink);
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .nav-toggle__bar + .nav-toggle__bar { margin-top: 3px; }
  .nav-toggle__label { display: inline-block; }

  /* Open state — turn the bars into an X */
  .site-header[data-nav-open="true"] .nav-toggle__bar:nth-child(1) {
    transform: translateY(4.5px) rotate(45deg);
  }
  .site-header[data-nav-open="true"] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .site-header[data-nav-open="true"] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-4.5px) rotate(-45deg);
  }

  @media (max-width: 760px) {
    /* Hide inline desktop nav, show toggle + overlay nav */
    .site-nav--inline { display: none; }

    /* Remove backdrop-filter on mobile — it creates a containing block that
       traps the position:fixed overlay inside the header's box. */
    .site-header {
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      background: var(--c-bg);
    }
    /* Lift brand + toggle above the fixed overlay (which is z:40). */
    .site-header__inner {
      padding-block: 0.85rem;
      gap: 1rem;
      position: relative;
      z-index: 50;
    }
    .brand__word { font-size: 1.3rem; }
    .brand__sub { display: none; }

    .nav-toggle { display: inline-flex; }

    /* Hide the desktop nav and prepare it as a fullscreen overlay. */
    .site-nav {
      position: fixed;
      inset: 0;
      background: var(--c-bg);
      padding: 6rem 2rem 3rem;
      z-index: 40;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: opacity 0.35s var(--ease), transform 0.35s var(--ease),
                  visibility 0.35s var(--ease);
      overflow-y: auto;
    }
    .site-nav ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }
    .site-nav li { width: 100%; border-bottom: 1px solid var(--c-line); }
    .site-nav li:last-child { border-bottom: none; }
    .site-nav a {
      display: flex;
      width: 100%;
      padding: 1.1rem 0;
      gap: 1rem;
      font-size: 1.4rem;
      font-family: var(--f-display);
      font-weight: 400;
      font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 0;
      letter-spacing: -0.012em;
      color: var(--c-ink);
    }
    .site-nav__num {
      display: inline-block;
      font-family: var(--f-mono);
      font-size: 0.66rem;
      color: var(--c-teal-deep);
      align-self: center;
      min-width: 1.5rem;
    }
    .site-nav a::after { display: none; }

    :root[data-nav-open="true"] .site-nav {
      opacity: 1;
      visibility: visible;
      transform: none;
    }
  }
</style>
