---
const nav = [
  { href: '#research', label: 'Research', n: 'I'   },
  { href: '#approach', label: 'Approach', n: 'II'  },
  { href: '#people',   label: 'People',   n: 'III' },
  { href: '#outputs',  label: 'Outputs',  n: 'IV'  },
  { href: '#updates',  label: 'Updates',  n: 'V'   },
  { href: '#contact',  label: 'Contact',  n: 'VI'  },
];
---

<header class="site-header">
  <div class="warming-stripes site-header__stripes" aria-hidden="true">
    {Array.from({ length: 20 }).map(() => <i></i>)}
  </div>

  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="CLICOPRE — home">
      <span class="brand__word">Clicopre</span>
      <span class="brand__sub">A research project</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href}>
              <span class="site-nav__num">{item.n}</span>
              <span class="site-nav__label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--c-bg) 92%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--c-line);
  }

  .site-header__stripes {
    height: 4px;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1.1rem 1.05rem;
  }

  /* ── Brand wordmark, editorial style ─────────────────── */
  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.05rem;
    color: var(--c-ink);
    line-height: 1;
  }
  .brand__word {
    font-family: var(--f-display);
    font-variation-settings: "opsz" 144, "SOFT" 60, "WONK" 1;
    font-weight: 420;
    font-size: 1.55rem;
    letter-spacing: -0.025em;
  }
  .brand__sub {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-muted);
    margin-top: 0.18rem;
  }

  /* ── Nav with roman numerals ─────────────────────────── */
  .site-nav ul {
    display: flex;
    gap: clamp(0.9rem, 2.2vw, 1.9rem);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .site-nav a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    font-family: var(--f-sans);
    font-size: 0.84rem;
    font-weight: 400;
    color: var(--c-ink-soft);
    padding: 0.5rem 0;
    position: relative;
  }
  .site-nav__num {
    font-family: var(--f-mono);
    font-size: 0.62rem;
    font-weight: 400;
    color: var(--c-ink-muted);
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }
  .site-nav__label {
    transition: color 0.3s ease;
  }
  .site-nav a::after {
    content: "";
    position: absolute;
    left: 0; right: 100%;
    bottom: 0.18rem;
    height: 1px;
    background: var(--c-teal);
    transition: right 0.45s var(--ease);
  }
  .site-nav a:hover { color: var(--c-ink); }
  .site-nav a:hover .site-nav__num { color: var(--c-teal-deep); }
  .site-nav a:hover::after { right: 0; }

  @media (max-width: 760px) {
    .site-header__inner { padding-block: 0.85rem; }
    .brand__word { font-size: 1.3rem; }
    .brand__sub { display: none; }
    .site-nav ul { gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end; }
    .site-nav a { font-size: 0.72rem; }
    .site-nav__num { display: none; }
  }
</style>
