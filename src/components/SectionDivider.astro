// ── Globe wireframe geometry ──────────────────────────────────────
// Meridians are rendered as cubic Bezier paths whose control points
// shift from left to right, producing the correct curvature change
// for a Y-axis (left-to-right) spin in orthographic projection:
//   • left edge  → path curves leftward  (matching globe outline)
//   • centre     → straight vertical line
//   • right edge → path curves rightward (matching globe outline)
// Each meridian is visible during the front-hemisphere pass (0-50%
// of its cycle) and hidden during the back pass (50-100%).
const nfSpinDur = 45; // seconds for one full rotation (matched to slower ticker)
const nfMeridianCount = 8;
const nfGTop = nfGlobeCy - nfGlobeR + 1; // 6
const nfGBot = nfGlobeCy + nfGlobeR - 1; // 84
// Three key path states (cubic Bézier: M start C cp1 cp2 end)
const nfPathL = `M ${nfGlobeCx} ${nfGTop} C ${nfGlobeCx - nfGlobeR} ${nfGTop} ${nfGlobeCx - nfGlobeR} ${nfGBot} ${nfGlobeCx} ${nfGBot}`;
const nfPathC = `M ${nfGlobeCx} ${nfGTop} C ${nfGlobeCx} ${nfGTop} ${nfGlobeCx} ${nfGBot} ${nfGlobeCx} ${nfGBot}`;
const nfPathR = `M ${nfGlobeCx} ${nfGTop} C ${nfGlobeCx + nfGlobeR} ${nfGTop} ${nfGlobeCx + nfGlobeR} ${nfGBot} ${nfGlobeCx} ${nfGBot}`;
// Parallels: proper half-ellipse rx at each latitude offset
const nfParallels = [-28, -16, -6, 6, 16, 28].map((off) => {
  const rxP = Math.sqrt(Math.max(0, nfGlobeR * nfGlobeR - off * off));
  // foreshortened ry gives 3D tilt perspective
  const ryP = Math.max(0.6, rxP * 0.08);
  return { cy: nfGlobeCy + off, rx: rxP, ry: ryP, isEquator: off === 0 };
});
