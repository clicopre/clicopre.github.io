  weather:  '#b8401f', // red — meteorological / climate (NOAA, ECMWF, WMO, Met Office, DWD, IPCC)
  media:    '#6b3fa0', // purple — broadcast (BBC)
  health:   '#0a8a7a', // teal — health / intl orgs (WHO, UN)
  sports:   '#c9722b', // amber — sports
  culture:  '#8b3a4f', // wine — cultural / awards
};
