// Dots are driven by client-side JS so they can rotate with the globe,
// disappear behind the horizon, and spawn expanding soundwave rings.
const nfTickerDur = 280; // slower: each of 40 items appears every ~7s
const nfDotData = nfPlaces.map((d, i) => ({
  lat: (d.lat / 180) * Math.PI,
  lon: (d.lon / 180) * Math.PI,
  color: nfThemeColors[nfItems[i]?.theme || 'news'] || nfThemeColors.news,
}));
