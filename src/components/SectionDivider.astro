---
// Compact inter-section dividers — small data-vis "interludes" between
// sections. No titles inside the viz; only an optional caption underneath.
//
//   heatwave  → climate · warming stripes
//   dispatch  → media flow · varied wire-service tape (drift left)
//   contour   → cross-country engagement · lines draw left → right
//   voice     → political talk-radio · two stacked speakers, fast waveform
//   network   → social media · Facebook ego-graph + hearts/hashtags
//   rollcall  → parliament · seats + 1 traveler at a time, soundwaves at desk

interface Props {
  variant: 'heatwave' | 'dispatch' | 'contour' | 'voice' | 'network' | 'rollcall' | 'newsfeed' | 'policy';
  caption?: string;
}

const { variant, caption } = Astro.props;

// ── Dispatch (wire-service teletype) ────────────────────────────
const dispatchFragments = [
  '— REUTERS', '· DG ·', 'COPENHAGEN', '— DISPATCH', '·· — ·', 'BRUSSELS',
  '— ANALYSIS', '· · WIRE', 'BERLIN', '— UPDATE', '·· POLL', 'MADRID',
  '— BREAKING', '· OPINION', 'WARSAW', '— BULLETIN', '·· EDIT', 'PRAGA',
  '— REUTERS-AP', '· COMMENT', 'LISBOA', '— EMBARGO', '·· DRAFT', 'ROMA',
  '— FILED', '· · DRAFT', 'PARIS', '— RECAST', '·· LEDE', 'WASHINGTON',
  '— REWRITE', '· STET', 'BUDAPEST', '— SLUG', '·· KILL', 'ATHENS',
  '— UNCONFIRMED', '· BACKGROUND', 'STOCKHOLM', '— OFF-RECORD', '·· FEED',
  'OSLO', '— EMBARGOED', '· — ·', 'DUBLIN', '— SOURCED', '·· LEAK',
];
const dispatchTape = (() => {
  const out: string[] = [];
  for (let i = 0; i < dispatchFragments.length * 3; i++) {
    out.push(dispatchFragments[(i * 7 + 3) % dispatchFragments.length]);
  }
  return out.join(' · ');
})();
const dispatchTapeLong = dispatchTape + '  ·  ' + dispatchTape;

// ── Contour (16 countries — US + 15 EU; 10 loops × 5 countries) ───
// 8-colour palette that repeats: countries 0-7 use solid lines,
// countries 8-15 reuse the same 8 colours with dashed lines.
const contourPalette = [
  '#2c5d8a', '#b8401f', '#0a8a7a', '#c9722b',
  '#6b3fa0', '#4a8c3a', '#c44535', '#0e1d28',
];
const contourCountries = [
  { code: 'BE',  label: 'Belgium',        color: contourPalette[0], thin: false },
  { code: 'CZ',  label: 'Czechia',        color: contourPalette[1], thin: false },
  { code: 'DK',  label: 'Denmark',        color: contourPalette[2], thin: false },
  { code: 'FI',  label: 'Finland',        color: contourPalette[3], thin: false },
  { code: 'FR',  label: 'France',         color: contourPalette[4], thin: false },
  { code: 'DE',  label: 'Germany',        color: contourPalette[5], thin: false },
  { code: 'IE',  label: 'Ireland',        color: contourPalette[6], thin: false },
  { code: 'IT',  label: 'Italy',          color: contourPalette[7], thin: false },
  { code: 'NL',  label: 'Netherlands',    color: contourPalette[0], thin: true },
  { code: 'PL',  label: 'Poland',         color: contourPalette[1], thin: true },
  { code: 'PT',  label: 'Portugal',       color: contourPalette[2], thin: true },
  { code: 'RO',  label: 'Romania',        color: contourPalette[3], thin: true },
  { code: 'SK',  label: 'Slovakia',       color: contourPalette[4], thin: true },
  { code: 'ES',  label: 'Spain',          color: contourPalette[5], thin: true },
  { code: 'UK',  label: 'United Kingdom', color: contourPalette[6], thin: true },
  { code: 'US',  label: 'United States',  color: contourPalette[7], thin: true },
];

// Round-robin schedule: 10 loops × 5 country indices each, picked from
// 0..15 in sequence (wrapping). Index i appears at positions i, i+16,
// i+32 of the flat sequence; the extra 2 positions (49, 50) recycle the
// first two countries. Result: 14 countries appear 3×, 2 appear 4×.
const contourPatternCount = 10;
const contourLinesPerPattern = 6;
const contourPatternCountries: number[][] = Array.from(
  { length: contourPatternCount },
  (_, p) =>
    Array.from(
      { length: contourLinesPerPattern },
      (_, j) => (p * contourLinesPerPattern + j) % contourCountries.length,
    ),
);

// y-axis uses 0–60 to match the network plot (netH = 60), so the contour
// paths have the same coordinate density and draw at the same visual speed.
const cW = 1200;
const cH = 60;
const segs = 220;
const contourCap = 100; // peaks can reach the top line

// One path per (pattern, country-in-pattern). The shape is seeded by
// the country's index (so each country has its own characteristic
// silhouette) and varied by the pattern index.
type ContourLine = { d: string; countryIdx: number; thin: boolean; len: number };
const contourPatterns: ContourLine[][] = contourPatternCountries.map((countryIndices, p) => {
  // Shared peak positions per pattern — all countries spike near the same x,
  // with small per-country jitter so lines stay correlated but not identical.
  const basePeaks = [
    { pos: cW * (0.12 + 0.04 * (p % 5)),       sig: cW * 0.014 },
    { pos: cW * (0.35 + 0.05 * ((p * 2) % 4)), sig: cW * 0.016 },
    { pos: cW * (0.58 + 0.04 * ((p + 1) % 4)), sig: cW * 0.015 },
    { pos: cW * (0.83 + 0.03 * ((p * 3) % 4)), sig: cW * 0.013 },
  ];

  return countryIndices.map((countryIdx, j) => {
    const row = countryIdx;
    // Per-country: position jitter ±3% and varied amplitude
    const peaks = basePeaks.map((bp, k) => ({
      pos: bp.pos + cW * 0.03 * Math.sin(row * 2.7 + k * 1.9 + p * 0.5),
      amp: 75 + ((row * 11 + p * 17 + k * 7) % 45),
      sig: bp.sig,
    }));

    // Per-country baseline — wider spread (2–18) with larger segment shifts
    const baseFloor = 2 + ((row * 7 + p * 3) % 17);          // 2–18 per country
    const baselines: number[] = [];
    for (let k = 0; k <= peaks.length; k++) {
      baselines.push(baseFloor + ((row * 5 + k * 11 + p * 13) % 13) - 4);  // ±shift per segment
    }

    const coords: { x: number; y: number }[] = [];
    const pts: string[] = [];
    for (let i = 0; i <= segs; i++) {
      const x = (i / segs) * cW;

      // Determine which segment we're in (between which peaks)
      let seg = peaks.length; // after last peak by default
      for (let k = 0; k < peaks.length; k++) {
        if (x < peaks[k].pos) { seg = k; break; }
      }
      // Smooth blend between adjacent segment baselines
      let bl: number;
      if (seg === 0) {
        bl = baselines[0];
      } else if (seg >= peaks.length) {
        bl = baselines[peaks.length];
      } else {
        const prev = peaks[seg - 1].pos;
        const next = peaks[seg].pos;
        const t = (x - prev) / (next - prev);
        bl = baselines[seg] * t + baselines[seg - 1] * (1 - t);
      }

      let v = bl +
        Math.sin(x * 0.010 + row * 1.3 + p * 0.9) * 1.0 +
        Math.sin(x * 0.027 + row * 0.7 + p * 1.7) * 0.6 +
        Math.sin(x * 0.061 + row * 2.1 + p * 0.4) * 0.3 +
        // High-frequency jiggle — small noisy oscillations
        Math.sin(x * 0.19 + row * 3.7 + p * 2.3) * 1.4 +
        Math.sin(x * 0.31 + row * 5.1 + p * 1.1) * 0.9 +
        Math.sin(x * 0.53 + row * 7.3 + p * 4.7) * 0.5;
      for (const pk of peaks) {
        const d = x - pk.pos;
        v += pk.amp * Math.exp(-(d * d) / (2 * pk.sig * pk.sig));
      }
      v = Math.max(0, Math.min(contourCap, v));
      const y = cH - v * (cH / 100);
      coords.push({ x, y });
      pts.push(`${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`);
    }
    // Compute actual path length so dasharray matches exactly (no hold, no gap)
    let len = 0;
    for (let i = 1; i < coords.length; i++) {
      const dx = coords[i].x - coords[i - 1].x;
      const dy = coords[i].y - coords[i - 1].y;
      len += Math.sqrt(dx * dx + dy * dy);
    }
    len = Math.ceil(len); // round up to be safe
    // Vary thin/normal weight per loop so each pattern shows a different mix
    const thin = ((p * 3 + j * 7) % 6) < 3;
    return { d: pts.join(' '), countryIdx, thin, len };
  });
});

// Synchronized with newsfeed/network: all lines in a pattern draw
// together over waveCrossDur (14s), timed to match the soundwave.
// Each pattern fires every dotInterval (10s).
const contourDrawDur = 15;       // matches waveCrossDur = dotInterval
const contourHoldDur = 0;
const contourPatternDur = contourDrawDur + contourHoldDur;
const contourCycleDur = contourPatternDur * contourPatternCount;
// Max path length across all contour lines — used for dasharray so every
// line draws at a consistent speed with no hold and no gap.
const contourMaxLen = Math.ceil(
  Math.max(...contourPatterns.flat().map((l) => l.len))
);
// Stops (as fractions of the whole cycle) for the per-path keyframe.
const contourDrawStop = (contourDrawDur / contourCycleDur * 100).toFixed(4);
const contourHoldStop = (contourPatternDur / contourCycleDur * 100).toFixed(4);

// ── Policy (CO₂ emissions reacting to legislation) ─────────────
// A single chart: erratic CO₂ line + vertical colored bands at each
// legislation event. Strong climate policy (blue, heat 0) pushes the
// line down; weak / rhetoric (red, heat 6) pushes it up. Vertical
// gradient legend on the right maps colour to policy strength 0–1.

const wsColors = ['#2c5d8a','#5a8db5','#9ebbd1','#d9d3c4','#e8b88a','#d97a4a','#b8401f'];

type PolicyItem = { text: string; heat: number };
const policyItems: PolicyItem[] = [
  { text: 'H.R. 1247 Energy Jobs',       heat: 5 },
  { text: 'Clean Air Act §4.2',           heat: 1 },
  { text: 'Res. 445 Growth Priority',     heat: 4 },
  { text: 'EU ETS Phase IV',              heat: 0 },
  { text: 'S. 892 Tax Relief',            heat: 5 },
  { text: 'H.R. 3340 Deregulation',       heat: 6 },
  { text: 'Res. 119 Market Freedom',      heat: 5 },
  { text: 'S. 201 Industrial Comp.',      heat: 6 },
  { text: 'H.R. 888 Energy Security',     heat: 4 },
  { text: 'Carbon Border Adj. Mech.',     heat: 0 },
  { text: 'Green Deal Fit-for-55',        heat: 0 },
  { text: 'Methane Reduction Dir.',       heat: 1 },
  { text: 'CO₂ Monitoring Reg.',          heat: 1 },
  { text: 'Renewable Portfolio Std.',     heat: 0 },
  { text: 'Res. 672 Fiscal Balance',      heat: 5 },
  { text: 'LULUCF Regulation',            heat: 1 },
  { text: 'S. 1450 Job Creation',         heat: 4 },
  { text: 'Emissions Trading Dir.',       heat: 0 },
  { text: 'H.R. 2214 Energy Indep.',      heat: 5 },
  { text: 'Climate Adaptation Fund',      heat: 0 },
  { text: 'Zero-Emission Vehicle Std.',   heat: 1 },
  { text: 'Nature Restoration Law',       heat: 0 },
  { text: 'Carbon Capture Incentive',     heat: 1 },
  { text: 'Sust. Finance Disclosure',     heat: 2 },
  { text: 'Res. 333 Competitiveness',     heat: 5 },
  { text: 'S. 478 Tax Simplification',    heat: 4 },
  { text: 'H.R. 5512 Growth Pact',        heat: 6 },
  { text: 'Res. 890 Market Access',       heat: 5 },
  { text: 'S. 311 Regulatory Relief',     heat: 6 },
  { text: 'Net-Zero Industry Act',        heat: 2 },
  { text: 'Dir. 2024/1 Climate Target',   heat: 3 },
];

const policyBandW = 4;
const policyChartH = 72;
const policyDur = 80;

// Deterministic pseudo-random
let _pSeed = 42;
const pRand = () => { _pSeed = (_pSeed * 1664525 + 1013904223) & 0x7fffffff; return _pSeed / 0x7fffffff; };

// Position each legislation event with irregular spacing
const policyEvents: { x: number; heat: number; text: string; color: string }[] = [];
let pX = 30;
policyItems.forEach((item) => {
  policyEvents.push({ x: pX, heat: item.heat, text: item.text, color: wsColors[item.heat] });
  pX += policyBandW + 55 + Math.floor(pRand() * 65);
});
const policyTotalW = pX + 30;

// Generate erratic CO₂ line that reacts to legislation
// Effect is delayed ~20px after each band and bleeds out over ~60px
const pStep = 7;
const pLinePts: { x: number; y: number }[] = [];
let co2 = policyChartH * 0.45;
let evtIdx = 0;
const pDelay = 20;  // px after band before effect starts
const pDecay = 0.92; // per-step decay of accumulated impulse
let impulse = 0;    // accumulated push waiting to bleed in
const pendingQueue: { xStart: number; strength: number }[] = [];
for (let x = 0; x <= policyTotalW; x += pStep) {
  // Queue new impulses from legislation events
  while (evtIdx < policyEvents.length && x >= policyEvents[evtIdx].x) {
    const h = policyEvents[evtIdx].heat;
    pendingQueue.push({ xStart: policyEvents[evtIdx].x + pDelay, strength: (3 - h) * 1.6 });
    evtIdx++;
  }
  // Activate queued impulses that have passed their delay
  for (let q = pendingQueue.length - 1; q >= 0; q--) {
    if (x >= pendingQueue[q].xStart) {
      impulse += pendingQueue[q].strength;
      pendingQueue.splice(q, 1);
    }
  }
  co2 += impulse * 0.18; // bleed impulse into position gradually
  impulse *= pDecay;      // decay the impulse over time
  co2 += (pRand() - 0.5) * 3.8;
  co2 += Math.sin(x * 0.035) * 0.6;
  co2 = Math.max(5, Math.min(policyChartH - 5, co2));
  pLinePts.push({ x, y: co2 });
}
// Converge last points toward start for seamless loop
const startY = pLinePts[0].y;
for (let i = 0; i < 10; i++) {
  const idx = pLinePts.length - 10 + i;
  const t = (i + 1) / 10;
  pLinePts[idx].y = pLinePts[idx].y * (1 - t) + startY * t;
}

// Smooth path via Catmull-Rom → cubic Bézier
function catmullRomPath(pts: { x: number; y: number }[]): string {
  if (pts.length < 2) return '';
  const d: string[] = [`M ${pts[0].x.toFixed(1)} ${pts[0].y.toFixed(1)}`];
  for (let i = 0; i < pts.length - 1; i++) {
    const p0 = pts[Math.max(0, i - 1)];
    const p1 = pts[i];
    const p2 = pts[i + 1];
    const p3 = pts[Math.min(pts.length - 1, i + 2)];
    const tension = 0.35;
    const cp1x = p1.x + (p2.x - p0.x) * tension;
    const cp1y = p1.y + (p2.y - p0.y) * tension;
    const cp2x = p2.x - (p3.x - p1.x) * tension;
    const cp2y = p2.y - (p3.y - p1.y) * tension;
    d.push(`C ${cp1x.toFixed(1)} ${cp1y.toFixed(1)} ${cp2x.toFixed(1)} ${cp2y.toFixed(1)} ${p2.x.toFixed(1)} ${p2.y.toFixed(1)}`);
  }
  return d.join(' ');
}

const policyLinePath = catmullRomPath(pLinePts);

// ── Voice (two stacked speakers, fast scrolling waveform) ───────
const voiceBarCount = 280;
const voiceBarW = 2.5;
const voiceBarGap = 1.6;
const voiceTrackH = 32;
const voiceMid = voiceTrackH;
const voiceTotalH = voiceTrackH * 2;
const voiceTotalW = voiceBarCount * (voiceBarW + voiceBarGap);

const turnEnv = (i: number, speaker: 0 | 1) => {
  const phase = speaker === 0 ? 0 : Math.PI;
  const slow = 0.5 + 0.5 * Math.tanh(2.6 * Math.sin(i * 0.018 + phase));
  const arc = 0.55 + 0.45 * Math.sin(i * 0.06 + phase * 0.4);
  return Math.max(0.04, slow * arc);
};

const speakerA = Array.from({ length: voiceBarCount }, (_, i) => {
  const v =
    Math.abs(Math.sin(i * 0.41 + 0.6)) * 0.40 +
    Math.abs(Math.sin(i * 1.13 + 1.3)) * 0.30 +
    Math.abs(Math.sin(i * 2.71 + 0.2)) * 0.20 +
    Math.abs(Math.sin(i * 5.30 + 1.9)) * 0.10;
  return Math.max(0.04, Math.min(1, v * turnEnv(i, 0)));
});
const speakerB = Array.from({ length: voiceBarCount }, (_, i) => {
  const v =
    Math.abs(Math.sin((i + 41) * 0.47 + 0.9)) * 0.40 +
    Math.abs(Math.sin((i + 41) * 1.21 + 0.5)) * 0.30 +
    Math.abs(Math.sin((i + 41) * 2.83 + 1.7)) * 0.20 +
    Math.abs(Math.sin((i + 41) * 5.91 + 0.8)) * 0.10;
  return Math.max(0.04, Math.min(1, v * turnEnv(i, 1)));
});

// ── Network (Facebook social graph) ─────────────────────────────
// ~92 organically scattered nodes. Each node has its own target degree
// (1–8) and connects to that many nearest neighbours (resulting graph
// can have higher degree where others link in). A small set of glyphs
// — hearts and hashtags — pop briefly above some vertices.
const netW = 1200;
const netH = 60;
const netNodeCount = 92;

const netRand = (i: number, salt: number) => {
  const s = Math.sin(i * 12.9898 + salt * 78.233) * 43758.5453;
  return s - Math.floor(s);
};

type NetNode = { x: number; y: number; r: number; isHub: boolean };
const netNodes: NetNode[] = Array.from({ length: netNodeCount }, (_, i) => {
  const x = 12 + netRand(i, 1) * (netW - 24);
  const y = 5 + netRand(i, 2) * (netH - 10);
  const isHub = (i * 11 + 3) % 11 === 0;
  const r = isHub ? 3.2 : 1.6 + netRand(i, 3) * 1.0;
  return { x, y, r, isHub };
});

// Per-node target degree in [1, 8], deterministic.
const netTargetDegree = (i: number) => 1 + ((i * 13 + 7) % 8);

const netEdgeKeys = new Set<string>();
const netEdges: { a: number; b: number }[] = [];
const addEdge = (a: number, b: number) => {
  const lo = Math.min(a, b);
  const hi = Math.max(a, b);
  const key = `${lo}-${hi}`;
  if (!netEdgeKeys.has(key)) {
    netEdgeKeys.add(key);
    netEdges.push({ a: lo, b: hi });
  }
};
for (let i = 0; i < netNodes.length; i++) {
  const k = netTargetDegree(i);
  const sorted = netNodes
    .map((n, j) => ({ j, d: Math.hypot(n.x - netNodes[i].x, n.y - netNodes[i].y) }))
    .filter(({ j }) => j !== i)
    .sort((p, q) => p.d - q.d)
    .slice(0, k);
  for (const { j } of sorted) addEdge(i, j);
}

// Identify connected components via union-find, then bridge the two
// largest components with two new "hub" vertices placed midway between
// their centroids.
const netParent = Array.from({ length: netNodes.length }, (_, i) => i);
const netFind = (x: number): number => {
  let r = x;
  while (netParent[r] !== r) r = netParent[r];
  while (netParent[x] !== r) {
    const next = netParent[x];
    netParent[x] = r;
    x = next;
  }
  return r;
};
const netUnion = (a: number, b: number) => {
  const ra = netFind(a);
  const rb = netFind(b);
  if (ra !== rb) netParent[ra] = rb;
};
for (const e of netEdges) netUnion(e.a, e.b);

const netCompMap = new Map<number, number[]>();
for (let i = 0; i < netNodes.length; i++) {
  const r = netFind(i);
  if (!netCompMap.has(r)) netCompMap.set(r, []);
  netCompMap.get(r)!.push(i);
}
const netComponents = Array.from(netCompMap.values()).sort((a, b) => b.length - a.length);

if (netComponents.length >= 2) {
  const compA = netComponents[0];
  const compB = netComponents[1];
  const centroid = (idxs: number[]) => {
    let sx = 0, sy = 0;
    for (const i of idxs) { sx += netNodes[i].x; sy += netNodes[i].y; }
    return { x: sx / idxs.length, y: sy / idxs.length };
  };
  const cA = centroid(compA);
  const cB = centroid(compB);
  const mx = (cA.x + cB.x) / 2;
  const my = (cA.y + cB.y) / 2;
  const bridge1Idx = netNodes.length;
  netNodes.push({ x: mx - 18, y: my - 4, r: 2.4, isHub: true });
  const bridge2Idx = netNodes.length;
  netNodes.push({ x: mx + 18, y: my + 4, r: 2.4, isHub: true });

  const nearestIn = (idxs: number[], from: { x: number; y: number }) => {
    let best = idxs[0];
    let bd = Infinity;
    for (const i of idxs) {
      const d = Math.hypot(netNodes[i].x - from.x, netNodes[i].y - from.y);
      if (d < bd) { bd = d; best = i; }
    }
    return best;
  };
  addEdge(bridge1Idx, nearestIn(compA, netNodes[bridge1Idx]));
  addEdge(bridge1Idx, nearestIn(compB, netNodes[bridge1Idx]));
  addEdge(bridge2Idx, nearestIn(compA, netNodes[bridge2Idx]));
  addEdge(bridge2Idx, nearestIn(compB, netNodes[bridge2Idx]));
  addEdge(bridge1Idx, bridge2Idx);
}

// Glyphs — small overlay symbols that pop and fade above some
// nodes. All six Facebook reactions. Positioned via percentage.
const netGlyphKinds = ['heart', 'thumb', 'haha', 'wow', 'sad', 'angry'] as const;
const netGlyphs = Array.from({ length: 30 }, (_, i) => {
  const nodeIdx = (i * 7 + 5) % netNodes.length;
  const node = netNodes[nodeIdx];
  return {
    leftPct: ((node.x / netW) * 100).toFixed(2),
    topPct: ((node.y / netH) * 100).toFixed(2),
    kind: netGlyphKinds[i % 6],
    delay: ((i * 0.71) % 9).toFixed(2),
  };
});

// Network globe dots — 10 positions cycling every ~8s. Each flash
// sends a soundwave across the network graph, triggering reactions.
// Each dot has a topic → colour (same palette as nfThemeColors).
// Colours inlined here because nfThemeColors is defined later in the file.
const netTopicColors: Record<string, string> = {
  news:     '#0e1d28',
  finance:  '#2c5d8a',
  weather:  '#b8401f',
  media:    '#6b3fa0',
  health:   '#0a8a7a',
  sports:   '#c9722b',
  culture:  '#8b3a4f',
};
const netGlobeDots = [
  { lat: 51.5, lon: -0.1,   topic: 'news' },     // London
  { lat: 40.7, lon: -74.0,  topic: 'finance' },   // New York
  { lat: 48.9, lon: 2.3,    topic: 'weather' },   // Paris
  { lat: 35.7, lon: 139.7,  topic: 'media' },     // Tokyo
  { lat: -22.9, lon: -43.2, topic: 'sports' },    // Rio
  { lat: 38.9, lon: -77.0,  topic: 'finance' },   // Washington
  { lat: 50.1, lon: 8.7,    topic: 'finance' },   // Frankfurt
  { lat: -33.9, lon: 18.4,  topic: 'news' },      // Cape Town
  { lat: 37.6, lon: 127.0,  topic: 'health' },    // Seoul
  { lat: 46.2, lon: 6.1,    topic: 'weather' },   // Geneva
].map((d) => ({
  lat: (d.lat / 180) * Math.PI,
  lon: (d.lon / 180) * Math.PI,
  color: netTopicColors[d.topic] || netTopicColors.news,
}));
const netGlobeDotsJSON = JSON.stringify(netGlobeDots);
const netGlyphDataJSON = JSON.stringify(netGlyphs.map(g => ({
  leftPct: parseFloat(g.leftPct),
  topPct: parseFloat(g.topPct),
  kind: g.kind,
})));

// ── Rollcall (elongated plenary chamber + 1-at-a-time speakers) ───
// 228 static seats over 4 elongated arcs. A cycle of 8 speakers walk
// to the desk one at a time. At the desk, the MP stays for ~5.6 seconds
// while hemicyclic "soundwaves" of its party colour expand outward into
// the chamber. After each wave reaches the rows, every other seat has a
// 0.8 probability of shifting to the speaker's party colour, and 0.2 of
// shifting against it. The whole sequence loops indefinitely.
const rcW = 1200;
const rcH = 60;
const rcCx = rcW / 2;
const rcCy = rcH; // virtual centre on the bottom edge — arcs sweep upward

const rcRows = [
  { rx: 360, ry: 22, count: 35 },
  { rx: 460, ry: 32, count: 42 },
  { rx: 540, ry: 42, count: 50 },
  { rx: 590, ry: 53, count: 55 },
];

const rcParties = [
  '#c2bfba',   // lightest warm gray
  '#b0ada8',
  '#9e9b96',   // mid-light
  '#8c8984',
  '#7a7772',   // mid-dark
  '#696660',   // darkest (still reads color)
];

// Seats are sampled by *arc length* (rather than uniform angle) over a
// reduced angular sweep, so they don't pile up at the edges and look
// evenly distributed across the chamber.
const rcAngleMin = Math.PI * 0.10;
const rcAngleMax = Math.PI * 0.90;
function evenArcAngles(rx: number, ry: number, count: number): number[] {
  const samples = 240;
  const cum: number[] = [0];
  const angs: number[] = [rcAngleMin];
  let prevX = rx * Math.cos(rcAngleMin);
  let prevY = ry * Math.sin(rcAngleMin);
  for (let i = 1; i <= samples; i++) {
    const a = rcAngleMin + (rcAngleMax - rcAngleMin) * (i / samples);
    const x = rx * Math.cos(a);
    const y = ry * Math.sin(a);
    cum.push(cum[cum.length - 1] + Math.hypot(x - prevX, y - prevY));
    angs.push(a);
    prevX = x; prevY = y;
  }
  const total = cum[cum.length - 1];
  const out: number[] = [];
  for (let k = 0; k < count; k++) {
    // k=0 → leftmost (highest angle); k=count-1 → rightmost (lowest angle).
    const target = total - (count === 1 ? total / 2 : (k / (count - 1)) * total);
    let i = 0;
    while (i < cum.length - 1 && cum[i + 1] < target) i++;
    const span = cum[i + 1] - cum[i] || 1;
    const f = (target - cum[i]) / span;
    out.push(angs[i] + f * (angs[i + 1] - angs[i]));
  }
  return out;
}

type RcSeat = { x: number; y: number; r: number; party: string };
const rcSeats: RcSeat[] = [];
for (const row of rcRows) {
  const angles = evenArcAngles(row.rx, row.ry, row.count);
  for (let i = 0; i < row.count; i++) {
    const t = i / (row.count - 1);
    const angle = angles[i];
    const x = rcCx + row.rx * Math.cos(angle);
    const y = rcCy - row.ry * Math.sin(angle);
    const partyIdx = Math.min(rcParties.length - 1, Math.floor(t * rcParties.length));
    rcSeats.push({ x, y, r: 3.1, party: rcParties[partyIdx] });
  }
}

