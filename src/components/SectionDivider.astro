            <div class="sd-policy__scroll">
              {[0, 1].map(() => (
                <div class="sd-policy__segment" style={`width: ${policyTotalW}px`}>
                  <svg viewBox={`0 0 ${policyTotalW} ${policyChartH}`} preserveAspectRatio="none">
                    {/* vertical bands at legislation events */}
                    {policyEvents.map((evt) => (
                      <rect
                        x={evt.x - policyBandW / 2}
                        y={0}
                        width={policyBandW}
                        height={policyChartH}
                        fill={evt.color}
                        class="sd-policy__band"
                      />
                    ))}
                    {/* baseline */}
                    <line x1="0" y1={policyChartH / 2} x2={policyTotalW} y2={policyChartH / 2}
                          class="sd-policy__baseline" />
                    {/* erratic CO₂ line */}
                    <path d={policyLinePath} class="sd-policy__line" />
                  </svg>
                </div>
              ))}
            </div>
          </div>
          <span class="sd-policy__time" aria-hidden="true">TIME</span>
          <div class="sd-policy__vlegend">
            <span class="sd-policy__vlegend-title">CLIMATE<br/>POLICY</span>
            <span class="sd-policy__vlegend-label">Strong</span>
            <div class="sd-policy__vlegend-bar"></div>
            <span class="sd-policy__vlegend-label">Weak</span>
          </div>
        </div>
      )}

      {variant === 'voice' && (
        <div class="sd-voice__plot">
          <svg viewBox={`0 0 ${voiceTotalW} ${voiceTotalH}`} preserveAspectRatio="none">
            <g class="sd-voice__scroller">
              {speakerA.map((h, i) => {
                const barH = h * voiceTrackH;
                return (
                  <rect
                    class="sd-voice__bar sd-voice__bar--a"
                    x={i * (voiceBarW + voiceBarGap)}
                    y={voiceMid - barH}
                    width={voiceBarW}
                    height={barH}
                    rx="0.6"
                  />
                );
              })}
              {speakerB.map((h, i) => {
                const barH = h * voiceTrackH;
                return (
                  <rect
                    class="sd-voice__bar sd-voice__bar--b"
                    x={i * (voiceBarW + voiceBarGap)}
                    y={voiceMid}
                    width={voiceBarW}
                    height={barH}
                    rx="0.6"
                  />
                );
              })}
              <g transform={`translate(${voiceTotalW}, 0)`}>
                {speakerA.map((h, i) => {
                  const barH = h * voiceTrackH;
                  return (
                    <rect
                      class="sd-voice__bar sd-voice__bar--a"
                      x={i * (voiceBarW + voiceBarGap)}
                      y={voiceMid - barH}
                      width={voiceBarW}
                      height={barH}
                      rx="0.6"
                    />
                  );
                })}
                {speakerB.map((h, i) => {
                  const barH = h * voiceTrackH;
                  return (
                    <rect
                      class="sd-voice__bar sd-voice__bar--b"
                      x={i * (voiceBarW + voiceBarGap)}
                      y={voiceMid}
                      width={voiceBarW}
                      height={barH}
                      rx="0.6"
                    />
                  );
                })}
              </g>
              <line
                x1="0"
                y1={voiceMid}
                x2={voiceTotalW * 2}
                y2={voiceMid}
                class="sd-voice__baseline"
              />
            </g>
          </svg>
        </div>
      )}

      {variant === 'network' && (
        <div class="sd-network-full"
             data-globe-dots={netGlobeDotsJSON}
             data-glyph-data={netGlyphDataJSON}
             data-spin={nfSpinDur}
             data-r={nfGlobeR}
             data-cx={nfGlobeCx}
             data-cy={nfGlobeCy}>
          {/* Globe — same wireframe as newsfeed */}
          <div class="sd-network-full__globe">
            <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <clipPath id="netGlobeClip">
                  <circle cx={nfGlobeCx} cy={nfGlobeCy} r={nfGlobeR - 0.5} />
                </clipPath>
                <radialGradient id="netGlobeShade" cx="38%" cy="34%" r="52%">
                  <stop offset="0%" stop-color="white" stop-opacity="0.07" />
                  <stop offset="70%" stop-color="white" stop-opacity="0" />
                  <stop offset="100%" stop-color="black" stop-opacity="0.05" />
                </radialGradient>
              </defs>
              <circle cx={nfGlobeCx} cy={nfGlobeCy} r={nfGlobeR} fill="url(#netGlobeShade)" stroke="var(--c-ink-soft)" stroke-width="1.1" />
              <g clip-path="url(#netGlobeClip)">
                {nfParallels.map((p) => (
                  <ellipse cx={nfGlobeCx} cy={p.cy} rx={p.rx} ry={p.ry} fill="none"
                    stroke={p.isEquator ? 'var(--c-ink-muted)' : 'var(--c-line-strong)'}
                    stroke-width={p.isEquator ? 0.6 : 0.35}
                    stroke-dasharray={p.isEquator ? '3 2' : '1.5 2.5'}
                    opacity={p.isEquator ? 0.7 : 0.45} />
                ))}
              </g>
              <g clip-path="url(#netGlobeClip)">
                {Array.from({ length: nfMeridianCount }, (_, m) => {
                  const phase = -(m * (nfSpinDur / nfMeridianCount));
                  return (
                    <path d={nfPathL} fill="none" stroke="var(--c-ink-muted)" stroke-width="0.45" opacity="0">
                      <animate attributeName="d" values={`${nfPathL};${nfPathC};${nfPathR};${nfPathL}`}
                        keyTimes="0;0.25;0.5;1" dur={`${nfSpinDur}s`} begin={`${phase}s`} repeatCount="indefinite" />
                      <animate attributeName="opacity" values="0.5;0.55;0.5;0;0;0.5"
                        keyTimes="0;0.25;0.48;0.5;0.97;1" dur={`${nfSpinDur}s`} begin={`${phase}s`} repeatCount="indefinite" />
                    </path>
                  );
                })}
              </g>
              {/* JS-driven dots */}
              <g clip-path="url(#netGlobeClip)" class="sd-netglobe__dots-layer">
                {netGlobeDots.map((_, i) => (
                  <Fragment>
                    <circle class="sd-netglobe-dot"  data-i={i} r="3.2" opacity="0" />
                  </Fragment>
                ))}
              </g>
            </svg>
          </div>

          {/* Network graph */}
          <div class="sd-network__plot sd-network__plot--inset">
            <svg viewBox={`0 0 ${netW} ${netH}`} preserveAspectRatio="none">
              {netEdges.map((e, i) => (
                <line x1={netNodes[e.a].x} y1={netNodes[e.a].y}
                      x2={netNodes[e.b].x} y2={netNodes[e.b].y}
                      class="sd-network__edge"
                      style={`animation-delay: ${(i % 19) * 0.17}s`} />
              ))}
              {netNodes.map((n, i) => (
                <circle cx={n.x} cy={n.y} r={n.r}
                  class={`sd-network__node ${n.isHub ? 'sd-network__node--hub' : ''}`}
                  style={`animation-delay: ${(i % 13) * 0.23}s`} />
              ))}
            </svg>
            <div class="sd-network__glyphs" aria-hidden="true">
              {netGlyphs.map((g, i) => (
                <span
                  class={`sd-network__glyph sd-network__glyph--${g.kind}`}
                  data-gi={i}
                  style={`left: ${g.leftPct}%; top: ${g.topPct}%`}
                >{g.kind === 'heart' ? '❤️' : g.kind === 'haha' ? '😂' : g.kind === 'wow' ? '😮' : g.kind === 'sad' ? '😢' : g.kind === 'angry' ? '😡' : ''}</span>
              ))}
            </div>
          </div>

          {/* Cross-element wave overlay — spans both globe and network */}
          <div class="sd-network__wave-overlay" aria-hidden="true"></div>
        </div>
      )}

      {variant === 'newsfeed' && (
        <div class="sd-newsfeed"
             style={`--nf-dur: ${nfTickerDur}s`}>
          <div class="sd-newsfeed__globe"
               data-dots={nfDotDataJSON}
               data-spin={nfSpinDur}
               data-ticker={nfTickerDur}
               data-r={nfGlobeR}
               data-cx={nfGlobeCx}
               data-cy={nfGlobeCy}>
            <svg viewBox="0 0 90 90" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <clipPath id="nfGlobeClip">
                  <circle cx={nfGlobeCx} cy={nfGlobeCy} r={nfGlobeR - 0.5} />
                </clipPath>
                <radialGradient id="nfGlobeShade" cx="38%" cy="34%" r="52%">
                  <stop offset="0%" stop-color="white" stop-opacity="0.07" />
                  <stop offset="70%" stop-color="white" stop-opacity="0" />
                  <stop offset="100%" stop-color="black" stop-opacity="0.05" />
                </radialGradient>
              </defs>

              {/* Globe fill — 3D shading */}
              <circle cx={nfGlobeCx} cy={nfGlobeCy} r={nfGlobeR} fill="url(#nfGlobeShade)" stroke="var(--c-ink-soft)" stroke-width="1.1" />

              {/* Parallels */}
              <g clip-path="url(#nfGlobeClip)">
                {nfParallels.map((p) => (
                  <ellipse
                    cx={nfGlobeCx}
                    cy={p.cy}
                    rx={p.rx}
                    ry={p.ry}
                    fill="none"
                    stroke={p.isEquator ? 'var(--c-ink-muted)' : 'var(--c-line-strong)'}
                    stroke-width={p.isEquator ? 0.6 : 0.35}
                    stroke-dasharray={p.isEquator ? '3 2' : '1.5 2.5'}
                    opacity={p.isEquator ? 0.7 : 0.45}
                  />
                ))}
              </g>

              {/* Meridians — cubic Bézier, SMIL-driven */}
              <g clip-path="url(#nfGlobeClip)">
                {Array.from({ length: nfMeridianCount }, (_, m) => {
                  const phase = -(m * (nfSpinDur / nfMeridianCount));
                  return (
                    <path
                      d={nfPathL}
                      fill="none"
                      stroke="var(--c-ink-muted)"
                      stroke-width="0.45"
                      opacity="0"
                    >
                      <animate
                        attributeName="d"
                        values={`${nfPathL};${nfPathC};${nfPathR};${nfPathL}`}
                        keyTimes="0;0.25;0.5;1"
                        dur={`${nfSpinDur}s`}
                        begin={`${phase}s`}
                        repeatCount="indefinite"
                      />
                      <animate
                        attributeName="opacity"
                        values="0.5;0.55;0.5;0;0;0.5"
                        keyTimes="0;0.25;0.48;0.5;0.97;1"
                        dur={`${nfSpinDur}s`}
                        begin={`${phase}s`}
                        repeatCount="indefinite"
                      />
                    </path>
                  );
                })}
              </g>

              {/* JS-driven dots — clipped to globe */}
              <g clip-path="url(#nfGlobeClip)" class="sd-newsfeed__dots-layer">
                {nfDotData.map((_, i) => (
                  <Fragment>
                    <circle class="sd-nf-dot" data-i={i} r="3.2" opacity="0" />
                  </Fragment>
                ))}
              </g>
            </svg>
          </div>

          {/* Content area: news ticker */}
          <div class="sd-newsfeed__content">
            <div class="sd-newsfeed__ticker">
              {nfItems.map((item) => (
                <div class="sd-newsfeed__item">
                  <span class="sd-newsfeed__source" style={`color: ${nfThemeColors[item.theme] || nfThemeColors.news}`}>{nfThemeLabels[item.theme] || 'NEWS'} — {item.source}</span>
                  <span class="sd-newsfeed__headline">{item.headline}</span>
                  <span class="sd-newsfeed__meta">{item.date} · {item.place}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Wave overlay — spans both globe and content area */}
          <div class="sd-newsfeed__wave-overlay" aria-hidden="true"></div>
        </div>
      )}

      {variant === 'rollcall' && (
        <div class="sd-rollcall__plot">
          <svg viewBox={`0 0 ${rcW} ${rcH}`} preserveAspectRatio="none">
            {/* Static seats with discrete fill animations driven by the
                speaker cycle. Seats reserved for speakers are skipped — the
                MP circles below render those positions instead. */}
            {rcSeats.map((seat, i) => {
              if (rcSpeakerSet.has(i)) return null;
              const timeline = rcSeatTimelines[i];
              const allSame = timeline.every((c) => c === timeline[0]);
              return (
                <circle
                  cx={seat.x}
                  cy={seat.y}
                  r={seat.r}
                  fill={timeline[0]}
                  class="sd-rollcall__seat"
                >
                  {!allSame && (
                    <animate
                      attributeName="fill"
                      values={timeline.join(';')}
                      keyTimes={rcColorKeyTimes}
                      dur={`${rcCycleDur}s`}
                      repeatCount="indefinite"
                      calcMode="discrete"
                    />
                  )}
                </circle>
              );
            })}

            {/* Hemicyclic soundwaves — half-ellipses that grow upward from
                the whole desk into the chamber. Three per speaker. */}
            {rcSpeakers.flatMap((sp) =>
              waveOffsetsSec.map((off) => {
                const burstStart = ((off) / rcCycleDur).toFixed(5);
                const burstMid   = ((off + waveDurSec * 0.5) / rcCycleDur).toFixed(5);
                const burstEnd   = ((off + waveDurSec) / rcCycleDur).toFixed(5);
                return (
                  <ellipse
                    cx={rcDeskX}
                    cy={rcDeskY}
                    rx={rcDeskHalfW}
                    ry={rcDeskHalfH}
                    fill="none"
                    stroke={sp.seat.party}
                    stroke-width="1.1"
                    opacity="0"
                    class="sd-rollcall__wave"
                  >
                    <animate
                      attributeName="rx"
                      values={`${rcDeskHalfW};${rcDeskHalfW};${rcW * 0.65};${rcW * 0.65}`}
                      keyTimes={`0;${burstStart};${burstEnd};1`}
                      dur={`${rcCycleDur}s`}
                      repeatCount="indefinite"
                      begin={`${sp.begin}s`}
                    />
                    <animate
                      attributeName="ry"
                      values={`${rcDeskHalfH};${rcDeskHalfH};${rcH * 1.3};${rcH * 1.3}`}
                      keyTimes={`0;${burstStart};${burstEnd};1`}
                      dur={`${rcCycleDur}s`}
                      repeatCount="indefinite"
                      begin={`${sp.begin}s`}
                    />
                    <animate
                      attributeName="opacity"
                      values={`0;0.85;0.55;0;0`}
                      keyTimes={`0;${burstStart};${burstMid};${burstEnd};1`}
                      dur={`${rcCycleDur}s`}
                      repeatCount="indefinite"
                      begin={`${sp.begin}s`}
                    />
                  </ellipse>
                );
              })
            )}

            {/* Desk — 3× thicker than before. Its fill animates to take on
                the active speaker's party colour while they stand behind it. */}
            <rect
              x={rcDeskX - rcDeskHalfW}
              y={rcDeskY - rcDeskHalfH}
              width={rcDeskHalfW * 2}
              height={rcDeskHalfH * 2}
              fill={rcDeskNeutral}
              class="sd-rollcall__desk"
            >
              <animate
                attributeName="fill"
                values={rcDeskColors}
                keyTimes={rcDeskKeyTimes}
                dur={`${rcCycleDur}s`}
                repeatCount="indefinite"
                calcMode="discrete"
              />
            </rect>

            {/* The speaker MPs: each walks from its seat to the middle of
                the desk (slightly behind) and back, sequentially. */}
            {rcSpeakers.map((sp) => {
              const sx = sp.seat.x;
              const sy = sp.seat.y;
              const dx = sp.dx;
              const dy = sp.dy;
              const party = sp.seat.party;
              return (
                <circle
                  cx={sx}
                  cy={sy}
                  r={sp.seat.r * 1.25}
                  fill={party}
                  class="sd-rollcall__mp"
                >
                  <animate
                    attributeName="cx"
                    values={`${sx};${dx};${dx};${sx};${sx}`}
                    keyTimes={mpKeyTimes}
                    dur={`${rcCycleDur}s`}
                    repeatCount="indefinite"
                    begin={`${sp.begin}s`}
                  />
                  <animate
                    attributeName="cy"
                    values={`${sy};${dy};${dy};${sy};${sy}`}
                    keyTimes={mpKeyTimes}
                    dur={`${rcCycleDur}s`}
                    repeatCount="indefinite"
                    begin={`${sp.begin}s`}
                  />
                </circle>
              );
            })}
          </svg>
        </div>
      )}
    </div>

    {caption && <p class="section-divider__caption">{caption}</p>}
  </div>
</aside>

<script>
  // ── Newsfeed: dot → cross-container wave → news reveal
  const nfContainer = document.querySelector<HTMLElement>('.sd-newsfeed');
  const nfGlobe = nfContainer?.querySelector<HTMLElement>('.sd-newsfeed__globe');
  if (nfContainer && nfGlobe) {
    const dots: { lat: number; lon: number; color: string }[] =
      JSON.parse(nfGlobe.dataset.dots || '[]');
    const spinDur = parseFloat(nfGlobe.dataset.spin || '30');
    const R  = parseFloat(nfGlobe.dataset.r  || '40');
    const cx = parseFloat(nfGlobe.dataset.cx || '45');
    const cy = parseFloat(nfGlobe.dataset.cy || '45');

    const dotEls   = nfGlobe.querySelectorAll<SVGCircleElement>('.sd-nf-dot');
    const overlay  = nfContainer.querySelector<HTMLElement>('.sd-newsfeed__wave-overlay');
    const contentEl = nfContainer.querySelector<HTMLElement>('.sd-newsfeed__content');
    const count    = dots.length;

    // ── Timing ──
    const waveCrossDur = 14.0;   // seconds for wave to cross full container
    const dotPulseSec  = 3.5;
    const revealSec    = 4.0;
    const holdSec      = 4.5;
    const fadeSec      = 1.0;
    const gapSec       = 0.5;
    const newsDur      = revealSec + holdSec + fadeSec; // 9.5s
    const dotInterval  = newsDur + gapSec;              // 10s

    // ── Ticker items ──
    const tickerEl = nfContainer.querySelector<HTMLElement>('.sd-newsfeed__ticker');
    const items = tickerEl
      ? Array.from(tickerEl.querySelectorAll<HTMLElement>('.sd-newsfeed__item')).slice(0, count)
      : [];

    // ── Geometry (re-measured on resize) ──
    const svgEl = nfGlobe.querySelector('svg');
    let cW = 1120, svgScale = 50 / 90, svgOffX = 15, svgOffY = 3;
    let contentLeft = 80, contentW = 1040, cH = 56;
    function measureLayout() {
      if (!svgEl) return;
      const sr = svgEl.getBoundingClientRect();
      const cr = nfContainer!.getBoundingClientRect();
      cW = cr.width;
      cH = cr.height;
      svgScale = sr.width / 90;
      svgOffX  = sr.left - cr.left;
      svgOffY  = sr.top  - cr.top;
      if (contentEl) {
        const ce = contentEl.getBoundingClientRect();
        contentLeft = ce.left - cr.left;
        contentW    = ce.width;
      }
    }
    measureLayout();
    window.addEventListener('resize', measureLayout);

    // ── Event queue ──
    interface Evt {
      idx: number;
      fire: number;
      screenX: number;
      screenY: number;
      front: boolean;
      color: string;
      ring: HTMLDivElement | null;
      newsTriggered: boolean;
    }
    const queue: Evt[] = [];
    let nextIdx  = 0;
    let nextFire = performance.now() / 1000;

    const reducedMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reducedMotion) {
      (function tick() {
        const t = performance.now() / 1000;
        const spinAngle = (t / spinDur) * Math.PI * 2;

        // ── Fire next dot? ──
        if (t >= nextFire) {
          // Find the next dot on the front hemisphere (scan up to all dots)
          let chosen = -1;
          for (let attempt = 0; attempt < count; attempt++) {
            const ci = (nextIdx + attempt) % count;
            const d  = dots[ci];
            const lon = d.lon + spinAngle;
            if (Math.cos(lon) > 0) { chosen = ci; break; }
          }

          if (chosen < 0) {
            // All dots on back — rare, retry shortly
            nextFire = t + 0.15;
          } else {
            const d   = dots[chosen];
            const lon = d.lon + spinAngle;
            const svgX = cx + R * 0.82 * Math.cos(d.lat) * Math.sin(lon);
            const svgY = cy - R * 0.82 * Math.sin(d.lat);
            const screenX = svgOffX + svgX * svgScale;
            const screenY = svgOffY + svgY * svgScale;

            // Event colour from the dot's topic (set at build time)
            const evtColor = dots[chosen].color;

            // Create cross-container wave ring
            let ring: HTMLDivElement | null = null;
            if (overlay) {
              ring = document.createElement('div');
              ring.className = 'sd-nf-cross-ring';
              ring.style.left = `${screenX}px`;
              ring.style.top  = `${screenY}px`;
              ring.style.borderColor = evtColor;
              overlay.appendChild(ring);
            }

            queue.push({
              idx: chosen, fire: t,
              screenX, screenY,
              front: true, color: evtColor, ring,
              newsTriggered: false,
            });
            nextIdx  = (chosen + 1) % count;
            nextFire = t + dotInterval;

            // Broadcast to network so it fires at the same instant
            window.dispatchEvent(new CustomEvent('clicopre-wave', { detail: { color: evtColor } }));
          }
        }

        // ── Position all dots (reset opacity first) ──
        for (let i = 0; i < count; i++) {
          const d   = dots[i];
          const lon = d.lon + spinAngle;
          const xi  = cx + R * 0.82 * Math.cos(d.lat) * Math.sin(lon);
          const yi  = cy - R * 0.82 * Math.sin(d.lat);
          const el  = dotEls[i];
          if (el) {
            el.setAttribute('cx', xi.toFixed(1));
            el.setAttribute('cy', yi.toFixed(1));
            el.setAttribute('opacity', '0');
          }
        }

        // ── Process active events ──
        for (let q = queue.length - 1; q >= 0; q--) {
          const ev = queue[q];
          const dt = t - ev.fire;

          // Finished — clean up
          if (dt > waveCrossDur + newsDur + 2) {
            const el = items[ev.idx];
            if (el) { el.style.opacity = '0'; el.style.clipPath = 'inset(0 100% 0 0)'; }
            if (ev.ring?.parentNode) ev.ring.remove();
            queue.splice(q, 1);
            continue;
          }

          const d   = dots[ev.idx];
          const lon = d.lon + spinAngle;
          const cosLon = Math.cos(lon);

          // 1. Dot pulse on globe
          if (dt < dotPulseSec) {
            const tN  = dt / dotPulseSec;
            const env = tN < 0.12 ? tN / 0.12 : Math.max(0, 1 - (tN - 0.12) / 0.88);
            const depth = cosLon > 0 ? 0.7 + 0.3 * cosLon : 0.15;
            const el  = dotEls[ev.idx];
            if (el) {
              el.setAttribute('fill', ev.color);
              el.setAttribute('opacity', (env * depth).toFixed(2));
              el.setAttribute('r', (3.0 + env * 0.8).toFixed(1));
            }
          }

          // 2. Wave ring expansion (JS-driven positioning)
          const maxRadius = cW * 1.5;
          if (ev.ring && dt > 0 && dt < waveCrossDur) {
            const wt = dt / waveCrossDur;
            const r  = wt * maxRadius;
            ev.ring.style.width  = `${r * 2}px`;
            ev.ring.style.height = `${r * 2}px`;
            ev.ring.style.opacity = Math.max(0, 0.75 * (1 - wt * 0.6)).toFixed(2);
          } else if (ev.ring && dt >= waveCrossDur) {
            if (ev.ring.parentNode) ev.ring.remove();
            ev.ring = null;
          }

          // Wave front radius at current time
          const waveFront = dt > 0 ? Math.min(1, dt / waveCrossDur) * maxRadius : 0;

          // 3. News reveal — triggered when wave front passes the content area left edge
          const distToContent = Math.max(0, contentLeft - ev.screenX);
          if (!ev.newsTriggered && waveFront >= distToContent && dt > 0) {
            ev.newsTriggered = true;
            // Source label colour is already set at build time from the topic
          }
          const el = items[ev.idx];
          if (el && ev.newsTriggered) {
            const newsT = dt - (distToContent / maxRadius) * waveCrossDur;
            if (newsT >= 0 && newsT < newsDur) {
              if (newsT < revealSec) {
                const frac = newsT / revealSec;
                el.style.clipPath = `inset(0 ${((1 - frac) * 100).toFixed(1)}% 0 0)`;
                el.style.opacity  = '1';
              } else if (newsT < revealSec + holdSec) {
                el.style.clipPath = 'inset(0 0 0 0)';
                el.style.opacity  = '1';
              } else {
                const f = (newsT - revealSec - holdSec) / fadeSec;
                el.style.clipPath = 'inset(0 0 0 0)';
                el.style.opacity  = Math.max(0, 1 - f).toFixed(2);
              }
            } else if (newsT >= newsDur) {
              el.style.opacity  = '0';
              el.style.clipPath = 'inset(0 100% 0 0)';
            }
          }

        }

        requestAnimationFrame(tick);
      })();
    } else {
      // Reduced motion: show first item statically
      if (items[0]) {
        items[0].style.opacity  = '1';
        items[0].style.clipPath = 'inset(0 0 0 0)';
      }
    }
  }
</script>

<script>
  // ── Contour: JS-driven draw synced to clicopre-wave events ──
  const contourEl = document.querySelector<HTMLElement>('.sd-contour');
  if (contourEl) {
    const patterns = Array.from(contourEl.querySelectorAll<SVGGElement>('.sd-contour__pattern'));
    const maxLen = parseInt(getComputedStyle(contourEl).getPropertyValue('--contour-len') || '1300', 10);

    // Compute drawDur so the contour drawing tip arrives at the right
    // edge at the same instant the soundwave ring front does.
    //
    // 1. Wave speed (px/s) = maxRadius / 14, where maxRadius = nfWidth × 1.5
    // 2. Time for wave to cross the *contour plot* width = plotWidth / waveSpeed
    // 3. stroke-dashoffset animates along *path length*, not horizontal
    //    distance. Peaks add extra length, so the tip's average horizontal
    //    speed is slower by the ratio maxLen / svgViewBoxWidth (1200).
    //    Multiply drawDur by that ratio so the rightmost point of the
    //    path is reached when the wave front passes it.
    let drawDur = 14.0 / 1.5;  // fallback
    const contourPlot = contourEl.querySelector<HTMLElement>('.sd-contour__plot');
    const nfBox = document.querySelector<HTMLElement>('.sd-newsfeed');
    if (contourPlot && nfBox) {
      const plotWidth = contourPlot.getBoundingClientRect().width;
      const nfW = nfBox.getBoundingClientRect().width;
      const maxRadius = nfW * 1.5;
      const waveSpeed = maxRadius / 14.0;                    // px / s
      const horizontalTime = plotWidth / waveSpeed;           // time for wave to cross plot
      const pathLengthRatio = maxLen / 1200;                  // path is longer than horizontal span
      drawDur = horizontalTime * pathLengthRatio;
    }

    const fadeDur = 0.6;
    let nextPattern = 0;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Active draws — each entry is cleaned up after fade
    type ContourDraw = { patternIdx: number; t0: number; fading: boolean };
    const active: ContourDraw[] = [];

    if (!reducedMotion) {
      window.addEventListener('clicopre-wave', () => {
        const pi = nextPattern % patterns.length;
        const paths = patterns[pi].querySelectorAll<SVGPathElement>('.sd-contour__path');
        // Reset each path using its own length
        paths.forEach(p => {
          const len = parseInt(p.dataset.len || '1200', 10);
          p.style.transition = '';
          p.style.opacity = '1';
          p.style.strokeDashoffset = `${len}`;
        });
        active.push({ patternIdx: pi, t0: performance.now() / 1000, fading: false });
        nextPattern++;
      });

      (function tick() {
        const t = performance.now() / 1000;
        for (let i = active.length - 1; i >= 0; i--) {
          const d = active[i];
          const dt = t - d.t0;
          const paths = patterns[d.patternIdx].querySelectorAll<SVGPathElement>('.sd-contour__path');

          if (dt < drawDur) {
            // Drawing phase — each path uses its own length so tips stay aligned
            const frac = dt / drawDur;
            paths.forEach(p => {
              const len = parseInt(p.dataset.len || '1200', 10);
              p.style.strokeDashoffset = (len * (1 - frac)).toFixed(1);
            });
          } else if (!d.fading) {
            // Draw complete — start fade
            d.fading = true;
            paths.forEach(p => {
              p.style.strokeDashoffset = '0';
              p.style.transition = `opacity ${fadeDur}s ease-out`;
              p.style.opacity = '0';
            });
          } else if (dt > drawDur + fadeDur + 0.1) {
            // Fade done — clean up
            paths.forEach(p => {
              const len = parseInt(p.dataset.len || '1200', 10);
              p.style.transition = '';
              p.style.strokeDashoffset = `${len}`;
            });
            active.splice(i, 1);
          }
        }
        requestAnimationFrame(tick);
      })();
    } else {
      // Reduced motion: show first pattern statically
      const paths = patterns[0]?.querySelectorAll<SVGPathElement>('.sd-contour__path');
      if (paths) paths.forEach(p => {
        p.style.opacity = '1';
        p.style.strokeDasharray = 'none';
        p.style.strokeDashoffset = '0';
      });
    }
  }
</script>

<script>
  // ── Network globe: spinning dots → cross-element soundwave → glyph reactions
  const netFull = document.querySelector<HTMLElement>('.sd-network-full');
  if (netFull) {
    const dots: { lat: number; lon: number; color: string }[] =
      JSON.parse(netFull.dataset.globeDots || '[]');
    const glyphData: { leftPct: number; topPct: number; kind: string }[] =
      JSON.parse(netFull.dataset.glyphData || '[]');
    const spinDur = parseFloat(netFull.dataset.spin || '28');
    const R  = parseFloat(netFull.dataset.r  || '40');
    const cx = parseFloat(netFull.dataset.cx || '45');
    const cy = parseFloat(netFull.dataset.cy || '45');

    const dotEls  = netFull.querySelectorAll<SVGCircleElement>('.sd-netglobe-dot');
    const glyphEls = netFull.querySelectorAll<HTMLElement>('.sd-network__glyph');
    const overlay = netFull.querySelector<HTMLElement>('.sd-network__wave-overlay');
    const plotEl  = netFull.querySelector<HTMLElement>('.sd-network__plot');

    const count = dots.length;
    const pulseSec = 3.5;
    const waveCrossDur = 14.0;        // seconds for wave to cross network (matches newsfeed)

    // ── Mobile: rescale network SVG viewBox so circles stay circular ──
    const isMobile = window.matchMedia('(max-width: 600px)').matches;
    if (isMobile && plotEl) {
      const netSvg = plotEl.querySelector('svg');
      if (netSvg) {
        const cW = plotEl.clientWidth;
        const cH = plotEl.clientHeight;
        const vbW = 1200;
        const vbH = 60;
        // New viewBox height that matches the container's aspect ratio
        const newVbH = vbW * cH / cW;
        const yScale = newVbH / vbH;
        netSvg.setAttribute('viewBox', `0 0 ${vbW} ${newVbH.toFixed(0)}`);

        // Scale y-coordinates of all nodes and edges
        netSvg.querySelectorAll<SVGCircleElement>('circle').forEach(c => {
          const cy = parseFloat(c.getAttribute('cy') || '0');
          c.setAttribute('cy', (cy * yScale).toFixed(1));
          // Enlarge nodes for mobile visibility
          const r = parseFloat(c.getAttribute('r') || '0');
          c.setAttribute('r', (r * 1.82).toFixed(1));
        });
        netSvg.querySelectorAll<SVGLineElement>('line').forEach(l => {
          const y1 = parseFloat(l.getAttribute('y1') || '0');
          const y2 = parseFloat(l.getAttribute('y2') || '0');
          l.setAttribute('y1', (y1 * yScale).toFixed(1));
          l.setAttribute('y2', (y2 * yScale).toFixed(1));
        });
      }
    }

    // Deterministic: which glyphs react to which dot flash.
    // ~40% of glyphs react to each wave, varied per dot.
    const glyphReactMap: boolean[][] = dots.map((_, di) =>
      glyphData.map((_, gi) => {
        const s = Math.sin(di * 137.5 + gi * 73.1) * 43758.5;
        return (s - Math.floor(s)) < 0.4;
      })
    );

    // Track which glyphs are currently animating to avoid overlap.
    const glyphBusy = new Array(glyphData.length).fill(false);

    const reducedMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reducedMotion) {
    // Animate a single glyph: pop up, float, fade out.
    function triggerGlyph(gi: number) {
      if (glyphBusy[gi]) return;
      const el = glyphEls[gi];
      if (!el) return;
      glyphBusy[gi] = true;
      el.animate([
        { opacity: 0, transform: 'translate(-50%, -100%) scale(0.7)', offset: 0 },
        { opacity: 1, transform: 'translate(-50%, -130%) scale(1.05)', offset: 0.15 },
        { opacity: 0.95, transform: 'translate(-50%, -150%) scale(1)', offset: 0.4 },
        { opacity: 0, transform: 'translate(-50%, -180%) scale(0.9)', offset: 1 },
      ], { duration: 1800, easing: 'ease-out', fill: 'forwards' })
      .addEventListener('finish', () => { glyphBusy[gi] = false; });
    }

    // Track active cross-element waves for glyph triggering.
    type ActiveWave = {
      startTime: number;
      originXPx: number;
      originYPx: number;
      color: string;
      dotIdx: number;
      ring: HTMLDivElement | null;
      triggered: boolean[];
    };
    const activeWaves: ActiveWave[] = [];

    // Network follows the newsfeed's timing via a shared event bus.
    // Pending fires queued here are consumed on the next rAF tick.
    let nextIdx = 0;
    const pendingFires: string[] = [];  // topic colors from newsfeed
    window.addEventListener('clicopre-wave', ((e: CustomEvent) => {
      pendingFires.push(e.detail.color);
    }) as EventListener);

    (function tick() {
      const t = performance.now() / 1000;
      const spinAngle = (t / spinDur) * Math.PI * 2;

      // ── Fire dot when newsfeed broadcasts an event ──
      while (pendingFires.length > 0) {
        const evtColor = pendingFires.shift()!;

        // Pick a front-hemisphere dot (round-robin)
        let chosen = -1;
        for (let attempt = 0; attempt < count; attempt++) {
          const ci = (nextIdx + attempt) % count;
          const d  = dots[ci];
          const lon = d.lon + spinAngle;
          if (Math.cos(lon) > 0) { chosen = ci; break; }
        }
        if (chosen < 0) continue; // all on back — skip

        // Record fire time + colour for this dot
        (dots[chosen] as any)._fireTime = t;
        (dots[chosen] as any)._fireColor = evtColor;
        nextIdx = (chosen + 1) % count;

        // Spawn cross-element wave ring
        const d = dots[chosen];
        const lon = d.lon + spinAngle;
        const x = cx + R * 0.82 * Math.cos(d.lat) * Math.sin(lon);
        const y = cy - R * 0.82 * Math.sin(d.lat);

        if (overlay) {
          const globeSvg = netFull.querySelector('.sd-network-full__globe svg');
          const svgRect = globeSvg?.getBoundingClientRect();
          const fullRect = netFull.getBoundingClientRect();
          if (svgRect && fullRect) {
            const svgScale = svgRect.width / 90;
            const dotScreenX = svgRect.left + x * svgScale - fullRect.left;
            const dotScreenY = svgRect.top + y * svgScale - fullRect.top;

            const ring = document.createElement('div');
            ring.className = 'sd-nf-cross-ring';
            ring.style.left = `${dotScreenX}px`;
            ring.style.top  = `${dotScreenY}px`;
            ring.style.borderColor = evtColor;
            overlay.appendChild(ring);

            activeWaves.push({
              startTime: t,
              originXPx: dotScreenX,
              originYPx: dotScreenY,
              color: evtColor,
              dotIdx: chosen,
              ring,
              triggered: new Array(glyphData.length).fill(false),
            });
          }
        }
      }

      // ── Position all dots + pulse active ones ──
      for (let i = 0; i < count; i++) {
        const d = dots[i];
        const lon = d.lon + spinAngle;
        const cosLon = Math.cos(lon);
        const x = cx + R * 0.82 * Math.cos(d.lat) * Math.sin(lon);
        const y = cy - R * 0.82 * Math.sin(d.lat);

        const dotEl = dotEls[i];
        if (dotEl) {
          dotEl.setAttribute('cx', x.toFixed(1));
          dotEl.setAttribute('cy', y.toFixed(1));

          const fireT = (d as any)._fireTime;
          const fireColor = (d as any)._fireColor || d.color;
          dotEl.setAttribute('fill', fireColor);
          const dt = fireT ? t - fireT : Infinity;
          if (dt < pulseSec) {
            const tN = dt / pulseSec;
            const env = tN < 0.12 ? tN / 0.12 : Math.max(0, 1 - (tN - 0.12) / 0.88);
            const depth = cosLon > 0 ? 0.7 + 0.3 * cosLon : 0.15;
            dotEl.setAttribute('opacity', (env * depth).toFixed(2));
            dotEl.setAttribute('r', (3.0 + env * 0.8).toFixed(1));
          } else {
            dotEl.setAttribute('opacity', '0');
          }
        }
      }

      // Check active waves → trigger glyphs.
      if (plotEl) {
        const plotRect = plotEl.getBoundingClientRect();
        const fullRect = netFull.getBoundingClientRect();
        const plotLeft = plotRect.left - fullRect.left;
        const plotW = plotRect.width;

        for (let wi = activeWaves.length - 1; wi >= 0; wi--) {
          const w = activeWaves[wi];
          const elapsed = t - w.startTime;

          if (elapsed > waveCrossDur + 2) {
            if (w.ring?.parentNode) w.ring.remove();
            activeWaves.splice(wi, 1);
            continue;
          }

          // JS-driven ring expansion (matches newsfeed approach)
          const maxRadius = fullRect.width * 1.5;
          if (w.ring && elapsed > 0 && elapsed < waveCrossDur) {
            const wt = elapsed / waveCrossDur;
            const r  = wt * maxRadius;
            w.ring.style.width  = `${r * 2}px`;
            w.ring.style.height = `${r * 2}px`;
            w.ring.style.opacity = Math.max(0, 0.75 * (1 - wt * 0.6)).toFixed(2);
          } else if (w.ring && elapsed >= waveCrossDur) {
            if (w.ring.parentNode) w.ring.remove();
            w.ring = null;
          }

          const waveFrontPx = Math.min(1, elapsed / waveCrossDur) * maxRadius;

          // Check each glyph.
          for (let gi = 0; gi < glyphData.length; gi++) {
            if (w.triggered[gi] || !glyphReactMap[w.dotIdx][gi]) continue;

            const g = glyphData[gi];
            const gx = plotLeft + (g.leftPct / 100) * plotW;
            const plotTop = plotRect.top - fullRect.top;
            const gy = plotTop + (g.topPct / 100) * plotRect.height;

            const dist = Math.hypot(gx - w.originXPx, gy - w.originYPx);

            if (waveFrontPx >= dist) {
              w.triggered[gi] = true;
              // Small delay after wave passes (0.1–0.3s).
              const delay = 100 + Math.random() * 200;
              setTimeout(() => triggerGlyph(gi), delay);
            }
          }
        }
      }

      requestAnimationFrame(tick);
    })();
    } // end if (!reducedMotion)
  }

  // ── Rollcall mobile: rescale viewBox so circles stay circular ──
  const rcPlot = document.querySelector<HTMLElement>('.sd-rollcall__plot');
  if (rcPlot && window.matchMedia('(max-width: 600px)').matches) {
    const rcSvg = rcPlot.querySelector('svg');
    if (rcSvg) {
      const cW = rcPlot.clientWidth;
      const cH = rcPlot.clientHeight;
      const vbW = 1200;
      const vbH = 60;
      const newVbH = vbW * cH / cW;
      const yScale = newVbH / vbH;
      rcSvg.setAttribute('viewBox', `0 0 ${vbW} ${newVbH.toFixed(0)}`);

      // Scale y-coords of all circles (seats + MPs)
      rcSvg.querySelectorAll<SVGCircleElement>('circle').forEach(c => {
        const cy = parseFloat(c.getAttribute('cy') || '0');
        c.setAttribute('cy', (cy * yScale).toFixed(1));
        // Scale r for visibility
        const r = parseFloat(c.getAttribute('r') || '0');
        c.setAttribute('r', (r * 1.3).toFixed(1));
        // Scale SMIL cy animations
        c.querySelectorAll('animate[attributeName="cy"]').forEach(a => {
          const vals = a.getAttribute('values');
          if (vals) {
            a.setAttribute('values', vals.split(';').map(v => (parseFloat(v) * yScale).toFixed(1)).join(';'));
          }
        });
      });

      // Scale ellipses (soundwaves): cy + ry
      rcSvg.querySelectorAll<SVGEllipseElement>('ellipse').forEach(e => {
        const cy = parseFloat(e.getAttribute('cy') || '0');
        const ry = parseFloat(e.getAttribute('ry') || '0');
        e.setAttribute('cy', (cy * yScale).toFixed(1));
        e.setAttribute('ry', (ry * yScale).toFixed(1));
        e.querySelectorAll('animate[attributeName="ry"]').forEach(a => {
          const vals = a.getAttribute('values');
          if (vals) {
            a.setAttribute('values', vals.split(';').map(v => (parseFloat(v) * yScale).toFixed(1)).join(';'));
          }
        });
      });

      // Scale rect (desk): y + height
      rcSvg.querySelectorAll<SVGRectElement>('rect').forEach(r => {
        const y = parseFloat(r.getAttribute('y') || '0');
        const h = parseFloat(r.getAttribute('height') || '0');
        r.setAttribute('y', (y * yScale).toFixed(1));
        r.setAttribute('height', (h * yScale).toFixed(1));
      });
    }
  }
</script>
