---
// Minimal light/dark mode toggle. Cycles: light → auto → dark.
// Persists choice in localStorage as `clicopre-mode`.
// Shows a sun (light), half-circle (auto), or moon (dark).
---

<button
  class="mode-btn"
  type="button"
  aria-label="Toggle light/dark mode"
  title="Toggle light/dark mode"
>
  <!-- Sun icon (light mode) -->
  <svg class="mode-btn__icon mode-btn__icon--light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <!-- Auto icon (half sun/moon) -->
  <svg class="mode-btn__icon mode-btn__icon--auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 7 A5 5 0 0 1 12 17 Z" fill="currentColor" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
  <!-- Moon icon (dark mode) -->
  <svg class="mode-btn__icon mode-btn__icon--dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  // Apply mode as early as possible to avoid a flash.
  (function () {
    try {
      var m = localStorage.getItem('clicopre-mode');
      if (m && m !== 'auto') document.documentElement.setAttribute('data-mode', m);
    } catch (e) {}
  })();
</script>

<script>
  const root = document.documentElement;
  const btn = document.querySelector<HTMLButtonElement>('.mode-btn');
  const modes = ['light', 'auto', 'dark'] as const;
  type Mode = typeof modes[number];

  const labels: Record<Mode, string> = {
    light: 'Light mode — click for auto',
    auto: 'Auto mode — click for dark',
    dark: 'Dark mode — click for light',
  };

  const getMode = (): Mode => (root.getAttribute('data-mode') as Mode) || 'auto';

  const apply = (m: Mode) => {
    if (m === 'auto') {
      root.removeAttribute('data-mode');
    } else {
      root.setAttribute('data-mode', m);
    }
    try { localStorage.setItem('clicopre-mode', m); } catch (e) {}
    if (btn) {
      btn.setAttribute('data-current', m);
      btn.setAttribute('aria-label', labels[m]);
      btn.setAttribute('title', labels[m]);
    }
  };

  btn?.addEventListener('click', () => {
    const cur = getMode();
    const next = modes[(modes.indexOf(cur) + 1) % modes.length];
    apply(next);
  });

  // Init
  apply(getMode());
</script>

<style>
  .mode-btn {
    position: fixed;
    right: 1.2rem;
    bottom: 1.2rem;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background: var(--c-bg);
    border: 1px solid var(--c-line-strong);
    color: var(--c-ink);
    cursor: pointer;
    border-radius: 50%;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease),
                background 0.2s ease, border-color 0.2s ease;
  }
  .mode-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.14);
    border-color: var(--c-teal);
  }
  .mode-btn:focus-visible {
    outline: 2px solid var(--c-teal-deep);
    outline-offset: 3px;
  }

  .mode-btn__icon {
    width: 18px;
    height: 18px;
    display: none;
  }

  /* Show the right icon based on data-current */
  .mode-btn[data-current="light"] .mode-btn__icon--light,
  .mode-btn[data-current="auto"] .mode-btn__icon--auto,
  .mode-btn[data-current="dark"] .mode-btn__icon--dark {
    display: block;
  }
  /* Before JS runs, default to auto */
  .mode-btn:not([data-current]) .mode-btn__icon--auto {
    display: block;
  }

  @media (max-width: 480px) {
    .mode-btn { right: 0.8rem; bottom: 0.8rem; width: 36px; height: 36px; }
    .mode-btn__icon { width: 16px; height: 16px; }
  }
</style>
