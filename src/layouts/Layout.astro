---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CLICOPRE — Climate Communication & Political Response',
  description = 'CLICOPRE studies how extreme weather events shape climate communication and political response in the EU and the US. A research project by Duccio Gamannossi degl\u2019Innocenti (University of Padua, Harvard University).',
} = Astro.props;

const siteUrl = 'https://clicopre.github.io';
const ogImage = `${siteUrl}/og.png`;

// Schema.org JSON-LD — helps Google Scholar and academic crawlers
// recognise this as a research project, with the PI as a Person.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ResearchProject',
      '@id': `${siteUrl}/#project`,
      name: 'CLICOPRE',
      alternateName: 'Climate Communication & Political Response',
      description,
      url: siteUrl,
      inLanguage: 'en',
      funding: {
        '@type': 'Grant',
        name: 'Marie Skłodowska-Curie Actions — Seal of Excellence',
        funder: [
          {
            '@type': 'Organization',
            name: 'Università degli Studi di Padova',
            url: 'https://www.unipd.it/',
          },
          {
            '@type': 'Organization',
            name: 'Fondazione Cassa di Risparmio di Padova e Rovigo',
            url: 'https://www.fondazionecariparo.it/',
          },
        ],
      },
      member: { '@id': `${siteUrl}/#pi` },
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#pi`,
      name: 'Duccio Gamannossi degl’Innocenti',
      jobTitle: 'Principal Investigator',
      affiliation: [
        { '@type': 'Organization', name: 'Università degli Studi di Padova' },
        { '@type': 'Organization', name: 'Harvard University' },
      ],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="climate communication, extreme weather, political response, NLP, causal inference, EU, US, MSCA, Marie Curie, University of Padua, Harvard" />
    <meta name="theme-color" content="#f4f1e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141110" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Default theme: Fraunces + IBM Plex Sans + IBM Plex Mono.
         Alternative themes load Newsreader/Literata/JetBrains Mono (Dispatch),
         Instrument Serif/Manrope/Space Mono (Frequency),
         Spectral/DM Sans/DM Mono (Cartograph).
         All families share one stylesheet so theme switching is instant. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..700,30..100,0..1&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,300..600&family=Literata:opsz,wght@7..72,300..600&family=JetBrains+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600&family=Space+Mono:wght@400;700&family=Spectral:wght@300;400;500;600&family=DM+Sans:opsz,wght@9..40,300..600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- If JS is disabled, scroll-reveal stays open instead of leaving content invisible. -->
    <noscript>
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    </noscript>

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl + '/'} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl + '/'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="CLICOPRE — How climate shocks shape political communication and the policy response." />
    <meta property="og:site_name" content="CLICOPRE" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ThemeSwitcher />

    <script>
      // Scroll-reveal via IntersectionObserver — no library.
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Scroll-spy — highlights the nav link for the section currently in view.
      const sections = document.querySelectorAll<HTMLElement>('section[id]');
      const navLinks = document.querySelectorAll<HTMLAnchorElement>('.site-nav a[href^="#"]');
      if (sections.length && navLinks.length) {
        const spy = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              const id = e.target.id;
              const link = document.querySelector(`.site-nav--inline a[href="#${id}"]`);
              if (link) link.classList.toggle('is-active', e.isIntersecting);
            }
          },
          { rootMargin: '-20% 0px -60% 0px' }
        );
        sections.forEach((s) => spy.observe(s));
      }
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
        background: var(--c-ink);
        color: var(--c-bg);
        padding: 0.6rem 1rem;
        border-radius: 6px;
        z-index: 100;
      }
    </style>
  </body>
</html>
