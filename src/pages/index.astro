---
import Layout from '../layouts/Layout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { getCollection } from 'astro:content';

const pillars = [
  {
    n: '01',
    title: 'Climate Communication',
    body: 'Measuring how extreme weather events reshape climate communication by politicians and news outlets on social media, and how audiences respond.',
    keys: ['Heatwaves', 'Floods', 'Engagement', 'Topic Analysis'],
  },
  {
    n: '02',
    title: 'Legislative Activity',
    body: 'Tracing whether weather-driven shifts in attention translate into climate-policy activity in the European Parliament and the US Congress.',
    keys: ['Roll-call votes', 'Bill sponsorship', 'Causal methods'],
  },
  {
    n: '03',
    title: 'Voting & Accountability',
    body: 'Assessing whether voters reward substantive policy responses over rhetoric on climate issues, and whether communication complements or substitutes for action.',
    keys: ['Elections', 'Policy response', 'Accountability', 'Causal designs'],
  },
];

const approach = [
  {
    label: 'Data',
    text: 'Large-scale social media data, news-outlet profiles, parliamentary records, and high-resolution weather information.',
  },
  {
    label: 'Methods',
    text: 'NLP and AI models combined with causal-inference designs that leverage the timing and intensity of weather shocks.',
  },
  {
    label: 'Outputs',
    text: 'Working papers, replication code, open datasets, policy-facing writing, and interactive evidence interfaces.',
  },
];

// Output streams. When real artefacts arrive, drop entries into the
// `items` arrays — each item should have { date, title, venue?, href? }.
const outputStreams = [
  { label: 'Papers',     hint: 'Working papers and journal articles will appear here as drafts circulate.', items: [] },
  { label: 'Data',       hint: 'Replication datasets will be released alongside each paper.', items: [] },
  { label: 'Code',       hint: 'Analysis code repositories will be linked here on first release.', items: [] },
];

// Updates / blog — auto-populated from src/content/updates/*.md
const updatePosts = await getCollection('updates', ({ data }) => !data.draft);
const updates = updatePosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((p) => ({
    date: p.data.date.toISOString().slice(0, 10),
    title: p.data.title,
    excerpt: p.data.excerpt,
  }));
---

<Layout>

  <!-- ───────────────── HERO ───────────────── -->
  <section class="hero">
    <div class="hero__gradient" aria-hidden="true"></div>
    <div class="container hero__inner">
      <aside class="hero__meta">
        <p class="meta-line">§&nbsp;CLICOPRE</p>
        <p class="meta-line">Climate communication and policy responses to extreme weather events</p>
        <p class="meta-line">2026 — 2029</p>
      </aside>

      <div class="hero__main">
        <p class="eyebrow reveal">Climate shocks · Communication · Policy response</p>

        <h1 class="hero__title reveal" data-delay="1">
          <em>Extreme Weather Events</em> and their impact on climate communication and policy responses.
        </h1>

        <p class="hero__lede reveal" data-delay="2">
          CLICOPRE studies how extreme weather events shift the climate debate
          among politicians and news outlets on social media, how audiences respond,
          and whether these shocks translate into legislative action and voting behavior
          in the European Union and the United States.
        </p>

        <div class="hero__cta reveal" data-delay="3">
          <a class="btn btn-primary" href="#research">
            Main research questions <span class="arrow">→</span>
          </a>
          <a class="btn btn-ghost" href="#approach">
            Methods &amp; data <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

<!-- ───────────────── SCOPE STRIP ───────────────── -->
  <!-- A factual rail summarising the project's scope. No roman numeral —
       this is an annotation between sections, not a section in its own right. -->
  <section class="scope-strip" aria-label="Project scope">
    <div class="container scope-strip__inner">
      <div class="scope-strip__cell reveal">
        <span class="scope-strip__label">Data</span>
        <span class="scope-strip__value">Weather</span>
        <span class="scope-strip__value">Social media</span>
        <span class="scope-strip__value">Legislative activity</span>
      </div>
      <div class="scope-strip__cell reveal" data-delay="1">
        <span class="scope-strip__label">Coverage</span>
        <span class="scope-strip__value">EU (<span class="count-up" data-target="15">0</span> countries)</span>
        <span class="scope-strip__value">US</span>
      </div>
      <div class="scope-strip__cell reveal" data-delay="2">
        <span class="scope-strip__label">Period</span>
        <span class="scope-strip__value tabular"><span class="count-up" data-target="2000">0</span>&nbsp;-&nbsp;<span class="count-up" data-target="2024">0</span></span>
      </div>
      <div class="scope-strip__cell reveal" data-delay="3">
        <span class="scope-strip__label">Methods</span>
        <span class="scope-strip__value">NLP &amp; Causal inference</span>
      </div>
    </div>
  </section>

  <!-- ───────────────── §I RESEARCH PILLARS ───────────────── -->
  <section id="research">
    <div class="container">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ I — Research agenda</span>
        </div>
        <h2>Three intertwined questions about climate, attention, and democratic accountability.</h2>
      </header>

      <div class="pillars">
        {pillars.map((p, i) => (
          <article class="pillar reveal" tabindex="0" data-delay={String(i + 1)}>
            <header class="pillar__head">
              <span class="pillar__n tabular">— {p.n}</span>
              <h3 class="pillar__title">{p.title}</h3>
            </header>
            <p class="pillar__body">{p.body}</p>
            <ul class="pillar__keys">
              {p.keys.map((k) => <li>{k}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider variant="newsfeed" />


  <!-- ───────────────── §II APPROACH ───────────────── -->
  <section id="approach" class="alt">
    <div class="container">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ II — Methods &amp; data</span>
        </div>
        <h2>Large-scale data, NLP, and AI for causal insight.</h2>
      </header>

      <ul class="approach__list">
        {approach.map((a, i) => (
          <li class="approach__item reveal" data-delay={String(i + 1)}>
            <span class="approach__label">{a.label}</span>
            <p>{a.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <SectionDivider variant="network" />

  <!-- ───────────────── §III PEOPLE ───────────────── -->
  <section id="people">
    <div class="container two-col">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ III — People &amp; institutions</span>
        </div>
        <h2>Hosted at the <strong>University of Padua</strong> and <strong>Harvard University</strong>.</h2>
      </header>
      <div class="reveal" data-delay="1">
        <p>
          CLICOPRE is led by <a class="link" href="https://www.dgdi.me" target="_blank" rel="noreferrer">Duccio Gamannossi degl&rsquo;Innocenti</a>, a postdoctoral researcher
          whose work spans public economics, political economy, climate, and media.
        </p>
        <p>
          The project runs under the <a class="link" href="https://www.unipd.it/en/msca-seal-excellence2025" target="_blank" rel="noreferrer"><strong>MSCA Seal of Excellence@UNIPD</strong></a>.
          The inbound phase is hosted at the <a class="link" href="https://www.economia.unipd.it/en" target="_blank" rel="noreferrer">Department of Economics and Management &ldquo;Marco Fanno&rdquo;</a>
          at the <strong>University of Padua</strong>. The outbound phase is hosted at the <a class="link" href="https://gov.harvard.edu" target="_blank" rel="noreferrer">Department of Government</a>,
          <strong>Harvard University</strong>.
        </p>
      </div>
    </div>
  </section>

  <SectionDivider variant="contour" />

  <!-- ───────────────── §IV OUTPUTS ───────────────── -->
  <section id="outputs" class="alt">
    <div class="container">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ IV — Outputs</span>
        </div>
        <h2>Papers, data, code, and interactive interfaces.</h2>
      </header>

      <div class="streams">
        {outputStreams.map((s, i) => (
          <article class="stream reveal" data-delay={String(i + 1)}>
            <header class="stream__head">
              <span class="stream__label">{s.label}</span>
              <span class="stream__count tabular">— {s.items.length}</span>
            </header>
            {s.items.length === 0 ? (
              <p class="stream__empty">{s.hint}</p>
            ) : (
              <ul class="stream__list">
                {s.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>

    </div>
  </section>


  <SectionDivider variant="rollcall" />

  
  
<!-- ───────────────── §V UPDATES ───────────────── -->
  <section id="updates">
    <div class="container">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ V — Updates</span>
        </div>
        <h2>News from the project.</h2>
      </header>

      {updates.length === 0 ? (
        <div class="updates__empty reveal" data-delay="1">
          <span class="meta-line">— First post coming soon</span>
          <p>
            Project updates, including working papers, data releases, dashboards, and events, will appear here.
          </p>
        </div>
      ) : (
        <ul class="updates__list">
          {updates.map((u, i) => (
            <li class="update reveal" data-delay={String(i + 1)}>
              <a href={u.href ?? '#'} class="update__link">
                <span class="update__date meta-line">{u.date}</span>
                <h3 class="update__title">{u.title}</h3>
                <p class="update__excerpt">{u.excerpt}</p>
                <span class="update__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>


  <SectionDivider variant="policy" />


  <!-- ───────────────── §VI CONTACT ───────────────── -->
  <section id="contact" class="alt tight">
    <div class="container contact">
      <header class="section-head reveal">
        <div class="section-rail">
          <span class="section-marker">§ VI — Contact</span>
        </div>
        <h2>Get in touch.</h2>
      </header>
      <p class="reveal" data-delay="1">
        For questions, clarifications, or collaboration, reach out at clicopre-AT-gmail.com.
      </p>
    </div>
  </section>
</Layout>

<script>
  // ── Count-up animation on scope strip numbers ──
  const counters = document.querySelectorAll<HTMLElement>('.count-up');
  if (counters.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const duration = target > 100 ? 1200 : 800;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
          el.textContent = String(Math.round(ease * target));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        io.unobserve(el);
      }
    }, { threshold: 0.5 });
    counters.forEach((c) => io.observe(c));
  }

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Parallax on section dividers ──
  if (!reducedMotion) {
    const dividers = document.querySelectorAll<HTMLElement>('[class*="sd-"][class*="__plot"], [class*="sd-"][class*="__globe"]');
    if (dividers.length) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const vh = window.innerHeight;
          dividers.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.bottom > 0 && rect.top < vh) {
              const center = (rect.top + rect.height / 2) / vh - 0.5; // -0.5 to 0.5
              el.style.transform = `translateY(${center * -12}px)`;
            }
          });
          ticking = false;
        });
      }, { passive: true });
    }
  }

  // ── Typing reveal on hero title italic ──
  if (!reducedMotion) {
    const em = document.querySelector<HTMLElement>('.hero__title em');
    if (em) {
      const text = em.textContent || '';
      em.textContent = '';
      em.style.borderRight = '2px solid var(--c-teal)';
      let i = 0;
      const type = () => {
        if (i < text.length) {
          em.textContent = text.slice(0, i + 1);
          i++;
          setTimeout(type, 45 + Math.random() * 30);
        } else {
          // Remove cursor after typing
          setTimeout(() => { em.style.borderRight = 'none'; }, 600);
        }
      };
      // Start after reveal animation completes
      setTimeout(type, 800);
    }
  }

  // ── Pillar card 3D tilt on hover ──
  const pillars = document.querySelectorAll<HTMLElement>('.pillar');
  if (!reducedMotion) {
    pillars.forEach((card) => {
      card.style.transition += ', transform 0.3s ease';
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;  // -0.5 to 0.5
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(600px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }
</script>

<style>
  /* ─────────────────────── HERO ─────────────────────── */
  .hero {
    position: relative;
    padding-top: clamp(5rem, 11vw, 9.5rem);
    padding-bottom: 0;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__gradient {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.12;
    background: linear-gradient(
      135deg,
      var(--ws-1) 0%, var(--ws-2) 14%, var(--ws-3) 28%,
      var(--ws-4) 42%, var(--ws-5) 56%, var(--ws-6) 70%,
      var(--ws-7) 84%, var(--ws-1) 100%
    );
    background-size: 300% 300%;
    animation: heroGradientShift 20s ease infinite;
  }
  @keyframes heroGradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__gradient { animation: none; }
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 12rem minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding-bottom: clamp(4rem, 8vw, 6.5rem);
  }

  .hero__meta {
    display: grid;
    align-content: start;
    gap: 0.18rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--c-line);
  }
  .hero__meta .meta-line { margin: 0; }

  /* On small screens the meta sidebar collapses to a horizontal strip
     placed BELOW the title, so it doesn't push the headline below the
     fold. */
  @media (max-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }
    .hero__main { order: 1; }
    .hero__meta {
      order: 2;
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1.4rem;
      padding-top: 1.1rem;
      margin-top: 0.4rem;
    }
  }

  .hero__main {
    position: relative;
  }
  .hero__title {
    font-size: clamp(2.6rem, 6.2vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0.4rem 0 1.6rem;
    max-width: 18ch;
    text-wrap: balance;
  }
  .hero__title em {
    font-style: italic;
    color: var(--c-teal-deep);
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }
  .hero__lede {
    font-size: var(--step-1);
    color: var(--c-ink-soft);
    max-width: 58ch;
    margin: 0 0 2.2rem;
    line-height: 1.55;
  }
  .hero__cta {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  /* ─────────────────────── PILLARS ─────────────────────── */
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--c-line);
  }
  @media (max-width: 880px) {
    .pillars { grid-template-columns: 1fr; }
  }
  .pillar {
    position: relative;
    padding: 2rem 1.8rem 2.4rem 0;
    border-right: 1px solid var(--c-line);
    transition: background-color 0.4s ease;
  }
  .pillar:last-child { border-right: none; }
  @media (max-width: 880px) {
    .pillar {
      border-right: none;
      border-bottom: 1px solid var(--c-line);
      padding: 1.8rem 0 2rem;
    }
    .pillar:last-child { border-bottom: none; }
  }
  .pillar__head {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 0.7rem;
  }
  .pillar__n {
    font-family: var(--f-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--c-teal-deep);
    letter-spacing: 0.04em;
  }
  .pillar__title {
    margin: 0;
    font-size: var(--step-2);
  }
  .pillar__body {
    margin: 0 0 1.3rem;
    color: var(--c-ink-soft);
    max-width: 32ch;
  }
  .pillar__keys {
    list-style: none;
    margin: 0;
    padding: 1rem 0 0;
    border-top: 1px dashed var(--c-line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.9rem;
  }
  .pillar__keys li {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    color: var(--c-ink-muted);
    letter-spacing: 0.02em;
  }
  .pillar__keys li::before {
    content: "· ";
    color: var(--c-teal);
    margin-right: 0.15rem;
  }
  .pillar__arrow {
    position: absolute;
    bottom: 1.4rem;
    right: 1.4rem;
    font-family: var(--f-mono);
    font-size: 0.95rem;
    color: var(--c-ink-muted);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.45s var(--ease), transform 0.45s var(--ease),
                color 0.4s ease;
  }
  .pillar:hover,
  .pillar:focus-visible {
    background: color-mix(in srgb, var(--c-teal) 5%, transparent);
  }
  .pillar:focus-visible {
    outline: 2px solid var(--c-teal-deep);
    outline-offset: -2px;
  }
  .pillar:hover .pillar__arrow,
  .pillar:focus-visible .pillar__arrow,
  .pillar:focus-within .pillar__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--c-teal-deep);
  }
  /* on touch devices there is no hover — show the arrow always */
  @media (hover: none) {
    .pillar__arrow {
      opacity: 1;
      transform: none;
      color: var(--c-teal-deep);
    }
  }

  /* ─────────────────────── SCOPE STRIP ─────────────────────── */
  .scope-strip {
    padding-block: clamp(2.4rem, 4vw, 3.2rem);
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
    background: var(--c-bg-deep);
  }
  .scope-strip__inner {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.2rem, 2.5vw, 2.4rem);
  }
  @media (max-width: 760px) {
    .scope-strip__inner { grid-template-columns: repeat(2, 1fr); gap: 1.6rem 1.4rem; }
  }
  .scope-strip__cell {
    display: grid;
    gap: 0.5rem;
    padding-left: 1rem;
    border-left: 1px solid var(--c-line-strong);
    align-content: start;
  }
  .scope-strip__label {
    font-family: var(--f-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-teal-deep);
  }
  .scope-strip__value {
    font-family: var(--f-display);
    font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 0;
    font-size: var(--step-2);
    font-weight: 400;
    color: var(--c-ink);
    line-height: 1.1;
    letter-spacing: -0.012em;
  }

  /* ─────────────────────── APPROACH ─────────────────────── */
  .approach__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (max-width: 880px) {
    .approach__list { grid-template-columns: 1fr; }
  }
  .approach__item {
    border-top: 1px solid var(--c-line-strong);
    padding-top: 1.4rem;
  }
  .approach__label {
    display: block;
    font-family: var(--f-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-teal-deep);
    margin-bottom: 0.7rem;
  }
  .approach__item p { margin: 0; color: var(--c-ink-soft); }

  /* ─────────────────────── TWO-COLUMN ─────────────────────── */
  .two-col {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }
  @media (max-width: 880px) {
    .two-col { grid-template-columns: 1fr; }
  }
  .two-col .section-head { margin-bottom: 0; }
  .two-col p { max-width: var(--max-w-prose); }
  .two-col strong { color: var(--c-ink); font-weight: 500; }

  /* Lighten section headings so the display face feels less heavy. */
  .section-head h2 {
    font-weight: 360;
    font-variation-settings: "opsz" 96, "SOFT" 22, "WONK" 0;
    letter-spacing: -0.016em;
  }

  /* ─────────────────────── OUTPUT STREAMS ─────────────────────── */
  .streams {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
  }
  @media (max-width: 880px) {
    .streams { grid-template-columns: 1fr; }
  }
  .stream {
    padding: 1.8rem 1.6rem 2rem 0;
    border-right: 1px solid var(--c-line);
  }
  .stream:last-child { border-right: none; }
  @media (max-width: 880px) {
    .stream {
      border-right: none;
      border-bottom: 1px solid var(--c-line);
      padding: 1.6rem 0;
    }
    .stream:last-child { border-bottom: none; }
  }
  .stream__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 1rem;
